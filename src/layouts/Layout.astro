---
import '../styles/global.css';
import '../styles/rangley-styles.css';
import Nav from '../components/Nav.astro';
import ThemeBackground from '../components/ThemeBackground.astro';
import LegoBackground from '../components/LegoBackground.astro';

interface Props {
	title: string;
	description?: string;
	// 'live'  = full animated theme background (default, used on the landing page)
	// 'frosted' = theme blurred + dimmed behind content for readability on text-heavy pages
	background?: 'live' | 'frosted';
}

const { title, description = 'Anthony Guzzardo - Full-stack Developer', background = 'live' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
		<title>{title}</title>
		<meta name="description" content={description} />
		<slot name="head" />
		<script is:inline>
			// Load saved theme preference for initial render (prevents flash)
			const savedTheme = localStorage.getItem('portfolio-theme') || 'domain-warping';
			document.documentElement.setAttribute('data-theme', savedTheme);
			// Set dark mode class based on theme (domain-warping is dark)
			document.documentElement.classList.add('dark');
		</script>
	</head>
	<body class={background === 'frosted' ? 'bg-frosted' : undefined}>
		<ThemeBackground />
		<LegoBackground />
		{background === 'frosted' && <div class="bg-frost-scrim"></div>}
		<Nav />

		<slot />
	</body>
</html>