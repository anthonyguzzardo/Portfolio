  { id: 8, type: 'photo', src: 'https://picsum.photos/seed/landscape8/1200/800', thumb: 'https://picsum.photos/seed/landscape8/600/400', title: 'Sunrise Over the Wetlands', species: '', category: 'landscapes', location: 'Horicon Marsh, WI', date: '2025-06-21', forSale: true },
  { id: 9, type: 'photo', src: 'https://picsum.photos/seed/warbler9/1200/800', thumb: 'https://picsum.photos/seed/warbler9/600/400', title: 'Yellow Warbler on Branch', species: 'Setophaga petechia', category: 'birds', location: 'Magee Marsh, OH', date: '2025-05-10', forSale: true },
  { id: 10, type: 'photo', src: 'https://picsum.photos/seed/turtle10/1200/800', thumb: 'https://picsum.photos/seed/turtle10/600/400', title: 'Painted Turtle Sunbathing', species: 'Chrysemys picta', category: 'reptiles', location: 'Indiana Dunes, IN', date: '2025-07-28', forSale: false },
  { id: 11, type: 'photo', src: 'https://picsum.photos/seed/sandhill11/1200/800', thumb: 'https://picsum.photos/seed/sandhill11/600/400', title: 'Sandhill Cranes Migration', species: 'Antigone canadensis', category: 'birds', location: 'Jasper-Pulaski FWA, IN', date: '2025-11-01', forSale: true },
  { id: 12, type: 'photo', src: 'https://picsum.photos/seed/coyote12/1200/800', thumb: 'https://picsum.photos/seed/coyote12/600/400', title: 'Coyote in Snow', species: 'Canis latrans', category: 'mammals', location: 'Grand Teton NP, WY', date: '2026-02-14', forSale: true },
];

const stats = [
  { label: 'Lifers', value: 312, sub: '+18 this year', featured: true },
  { label: 'Field Hours', value: 1860, sub: 'Peak month: May' },
  { label: 'Hotspots Visited', value: 47, sub: 'Across 5 states' },
  { label: 'Photo Archive', value: 12480, sub: '82% from Midwest' },
  { label: 'New This Month', value: 14, sub: 'Best day: 9 species' },
] as const;

const signatureStat = {
  label: 'Rarest Sighting',
  value: 'Snowy Owl',
  detail: 'Illinois Beach State Park — March 2026',
  note: 'First state record in 3 years. Waited 4 hours in 18°F wind chill.',
};

const recentSightings = [
  { species: 'Pileated Woodpecker', location: 'Starved Rock, IL', date: '2026-03-28' },
  { species: 'American Kestrel', location: 'Midewin Tallgrass Prairie, IL', date: '2026-03-25' },
  { species: 'Snowy Owl', location: 'Illinois Beach State Park, IL', date: '2026-03-20' },
  { species: 'Northern Cardinal', location: 'Morton Arboretum, IL', date: '2026-03-18' },
  { species: "Cooper's Hawk", location: 'Waterfall Glen, IL', date: '2026-03-15' },
];

const stateVisits: Record<string, { name: string; visits: number; species: number; photos: number; topSpecies: string }> = {
  IL: { name: 'Illinois', visits: 45, species: 87, photos: 3200, topSpecies: 'Red-tailed Hawk' },
  WI: { name: 'Wisconsin', visits: 22, species: 54, photos: 1800, topSpecies: 'Sandhill Crane' },
  IN: { name: 'Indiana', visits: 18, species: 42, photos: 1200, topSpecies: 'Eastern Bluebird' },
  MI: { name: 'Michigan', visits: 15, species: 38, photos: 980, topSpecies: 'Common Loon' },
  OH: { name: 'Ohio', visits: 12, species: 45, photos: 850, topSpecies: 'Yellow Warbler' },
};

const fieldGuide = [
  { id: 1, name: 'Red-tailed Hawk', scientific: 'Buteo jamaicensis', img: 'https://picsum.photos/seed/rthawk/400/500', habitat: 'Open fields, forests', diet: 'Small mammals, birds', wingspan: '45-52 in', weight: '1.5-3.5 lb', status: 'Least Concern', firstSeen: '2024-03-12', location: 'Starved Rock, IL', sightings: 23, rarity: 'common' },
  { id: 2, name: 'Great Blue Heron', scientific: 'Ardea herodias', img: 'https://picsum.photos/seed/gbheron/400/500', habitat: 'Wetlands, shorelines', diet: 'Fish, amphibians', wingspan: '66-79 in', weight: '4.6-5.5 lb', status: 'Least Concern', firstSeen: '2024-04-08', location: "Chain O' Lakes, IL", sightings: 18, rarity: 'common' },
  { id: 3, name: 'Bald Eagle', scientific: 'Haliaeetus leucocephalus', img: 'https://picsum.photos/seed/baldeagle/400/500', habitat: 'Near large bodies of water', diet: 'Fish, waterfowl', wingspan: '71-91 in', weight: '6.6-14 lb', status: 'Least Concern', firstSeen: '2024-06-20', location: 'Mississippi River Valley, IA', sightings: 8, rarity: 'uncommon' },
  { id: 4, name: 'Great Horned Owl', scientific: 'Bubo virginianus', img: 'https://picsum.photos/seed/ghowl/400/500', habitat: 'Forests, swamps, deserts', diet: 'Mammals, birds, reptiles', wingspan: '40-57 in', weight: '2-5.5 lb', status: 'Least Concern', firstSeen: '2025-01-12', location: 'Morton Arboretum, IL', sightings: 5, rarity: 'uncommon' },
  { id: 5, name: 'Belted Kingfisher', scientific: 'Megaceryle alcyon', img: 'https://picsum.photos/seed/bkingfish/400/500', habitat: 'Streams, rivers, ponds', diet: 'Fish, crayfish', wingspan: '19-23 in', weight: '5-6 oz', status: 'Least Concern', firstSeen: '2025-07-04', location: 'Galena, IL', sightings: 3, rarity: 'uncommon' },
  { id: 6, name: 'Yellow Warbler', scientific: 'Setophaga petechia', img: 'https://picsum.photos/seed/ywarbler/400/500', habitat: 'Thickets, wetlands', diet: 'Insects, berries', wingspan: '6.3-7.9 in', weight: '0.3-0.4 oz', status: 'Least Concern', firstSeen: '2025-05-10', location: 'Magee Marsh, OH', sightings: 12, rarity: 'common' },
  { id: 7, name: 'Sandhill Crane', scientific: 'Antigone canadensis', img: 'https://picsum.photos/seed/shcrane/400/500', habitat: 'Marshes, grasslands', diet: 'Seeds, grains, insects', wingspan: '73-90 in', weight: '7.3-11 lb', status: 'Least Concern', firstSeen: '2025-11-01', location: 'Jasper-Pulaski FWA, IN', sightings: 15, rarity: 'common' },
  { id: 8, name: 'Snowy Owl', scientific: 'Bubo scandiacus', img: 'https://picsum.photos/seed/snowyowl/400/500', habitat: 'Open tundra, fields', diet: 'Lemmings, small mammals', wingspan: '49-59 in', weight: '3.5-6.5 lb', status: 'Vulnerable', firstSeen: '2026-03-20', location: 'Illinois Beach SP, IL', sightings: 1, rarity: 'rare' },
  { id: 9, name: 'Pileated Woodpecker', scientific: 'Dryocopus pileatus', img: 'https://picsum.photos/seed/pwood/400/500', habitat: 'Mature forests', diet: 'Carpenter ants, beetles', wingspan: '26-30 in', weight: '8.8-12.3 oz', status: 'Least Concern', firstSeen: '2026-03-28', location: 'Starved Rock, IL', sightings: 4, rarity: 'uncommon' },
  { id: 10, name: 'American Kestrel', scientific: 'Falco sparverius', img: 'https://picsum.photos/seed/akestrel/400/500', habitat: 'Open country, cities', diet: 'Insects, small birds', wingspan: '20-24 in', weight: '2.8-5.8 oz', status: 'Least Concern', firstSeen: '2026-03-25', location: 'Midewin Prairie, IL', sightings: 6, rarity: 'common' },
  { id: 11, name: 'Northern Cardinal', scientific: 'Cardinalis cardinalis', img: 'https://picsum.photos/seed/ncard/400/500', habitat: 'Woodlands, gardens', diet: 'Seeds, fruits, insects', wingspan: '10-12 in', weight: '1.5-1.7 oz', status: 'Least Concern', firstSeen: '2024-02-14', location: 'Morton Arboretum, IL', sightings: 47, rarity: 'common' },
  { id: 12, name: "Cooper's Hawk", scientific: 'Accipiter cooperii', img: 'https://picsum.photos/seed/coophawk/400/500', habitat: 'Forests, wooded suburbs', diet: 'Medium-sized birds', wingspan: '24-36 in', weight: '7.8-24 oz', status: 'Least Concern', firstSeen: '2026-03-15', location: 'Waterfall Glen, IL', sightings: 7, rarity: 'uncommon' },
  { id: 13, name: 'Common Loon', scientific: 'Gavia immer', img: 'https://picsum.photos/seed/cloon/400/500', habitat: 'Lakes, coastal waters', diet: 'Fish', wingspan: '41-52 in', weight: '6.5-12 lb', status: 'Least Concern', firstSeen: '2025-08-15', location: 'Traverse City, MI', sightings: 3, rarity: 'uncommon' },
  { id: 14, name: 'Eastern Bluebird', scientific: 'Sialia sialis', img: 'https://picsum.photos/seed/eblue/400/500', habitat: 'Open woodlands, farmland', diet: 'Insects, berries', wingspan: '9.8-12.6 in', weight: '0.95-1.2 oz', status: 'Least Concern', firstSeen: '2025-04-22', location: 'Brown County SP, IN', sightings: 9, rarity: 'common' },
];

const categories = ['all', 'birds', 'mammals', 'reptiles', 'landscapes'];

const iconPaths = [
  '<path d="M20.24 12.24a6 6 0 0 0-8.49-8.49L5 10.5V19h8.5z"/><line x1="16" y1="8" x2="2" y2="22"/>',
  '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  '<path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/>',
  '<path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>',
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Shakshuka | Wildlife Photography</title>
  <meta name="description" content="Wildlife and bird photography by Shakshuka. Capturing nature's finest moments across North America.">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
<script is:inline>
  if (localStorage.getItem('shakshuka-color-mode') === 'light') {
    document.body.classList.add('sk-light');
  }
</script>

  <!-- NAV -->
  <nav class="sk-nav" id="sk-nav">
    <div class="sk-nav-inner">
      <a href="#" class="sk-nav-logo">Shakshuka</a>
      <div class="sk-nav-right">
        <ul class="sk-nav-links" id="sk-nav-links">
          <li><a href="#gallery">Gallery</a></li>
          <li><a href="#field-guide">Field Guide</a></li>
          <li><a href="#stats">Stats</a></li>
          <li><a href="#map">Map</a></li>
          <li><a href={`mailto:${CONTACT_EMAIL}`}>Contact</a></li>
        </ul>
        <button class="sk-mode-toggle" id="sk-mode-toggle" aria-label="Toggle light/dark mode">
          <svg class="sk-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
          </svg>
          <svg class="sk-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
          </svg>
        </button>
        <button class="sk-nav-toggle" id="sk-nav-toggle" aria-label="Toggle navigation">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
          </svg>
        </button>
      </div>
    </div>
  </nav>

  <!-- HERO: The Perch -->
  <section class="sk-hero" id="the-perch">
    <button class="sk-perch-mode" id="sk-perch-mode" aria-label="Toggle light/dark mode">
      <svg class="sk-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="sk-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
    <div class="sk-perch-inner">
      <div class="sk-wordmark-area">
        <h1 class="sk-wordmark" id="sk-wordmark">
          <span class="sk-letter sk-letter-S">S</span><span class="sk-letter sk-letter-h1">h</span><span class="sk-letter sk-letter-a1">a</span><span class="sk-letter sk-letter-k1">k</span><span class="sk-letter sk-letter-s">s</span><span class="sk-letter sk-letter-h2">h</span><span class="sk-letter sk-letter-u">u</span><span class="sk-letter sk-letter-k2">k</span><span class="sk-letter sk-letter-a2">a</span>
        </h1>
      </div>
      <p class="sk-perch-tagline" id="sk-perch-tagline">Wildlife & Bird Photography</p>
      <nav class="sk-perch-nav" id="sk-perch-nav">
        <a href="#gallery">Gallery</a>
        <a href="#field-guide">Field Guide</a>
        <a href="#stats">Stats</a>
        <a href="#map">Map</a>
        <a href={`mailto:${CONTACT_EMAIL}`}>Contact</a>
      </nav>
    </div>
  </section>

  <!-- GALLERY -->
  <section id="gallery" class="sk-section">
    <div class="sk-container">
      <h2 class="sk-section-title sk-anim">Through the Lens</h2>
      <p class="sk-section-sub sk-anim">A curated collection of wildlife encounters</p>
      <div class="sk-filters sk-anim">
        {categories.map((cat, i) => (
          <button class={`sk-filter-btn${i === 0 ? ' active' : ''}`} data-filter={cat}>{cat}</button>
        ))}
      </div>
      <div class="sk-gallery-grid">
        {galleryItems.map(item => (
          <div class="sk-card sk-anim" data-category={item.category} data-id={item.id}>
            <img src={item.thumb} alt={item.title} loading="lazy" />
            {item.type === 'video' && (
              <div class="sk-play-icon">
                <svg viewBox="0 0 24 24" width="24" height="24" fill="white"><polygon points="8,5 19,12 8,19"/></svg>
              </div>
            )}
            {item.forSale && <span class="sk-badge">For Sale</span>}
            <div class="sk-card-overlay">
              <div class="sk-card-title">{item.title}</div>
              <div class="sk-card-loc">{item.location}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FIELD GUIDE -->
  <section id="field-guide" class="sk-section">
    <div class="sk-container">
      <h2 class="sk-section-title sk-anim">Field Guide</h2>
      <p class="sk-section-sub sk-anim">Flip through the life list — {fieldGuide.length} species catalogued &nbsp;<a href="/field-guide" class="sk-view-all">View All</a></p>

      <div class="sk-dex-search-wrap sk-anim">
        <div class="sk-dex-search-box">
          <svg class="sk-dex-search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
          <input type="text" class="sk-dex-search" id="dex-search" placeholder="Search species..." autocomplete="off" />
          <div class="sk-dex-suggestions" id="dex-suggestions"></div>
        </div>
      </div>

      <div class="sk-dex-shelf sk-anim">
        <button class="sk-dex-arrow sk-dex-arrow-left" id="dex-left" aria-label="Scroll left">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="sk-dex-track" id="dex-track">
          <div class="sk-dex-track-inner" id="dex-track-inner">
          {fieldGuide.map((bird) => (
            <div class="sk-dex-card" data-rarity={bird.rarity}>
              <div class="sk-dex-card-inner">
                <div class="sk-dex-front">
                  <div class="sk-dex-header">
                    <div class="sk-dex-number">Lifer #{String(bird.id).padStart(3, '0')} <span class="sk-dex-of">/ {fieldGuide.length}</span></div>
                    <div class="sk-dex-rarity">{bird.rarity}</div>
                  </div>
                  <div class="sk-dex-img-wrap">
                    <img src={bird.img} alt={bird.name} loading="lazy" />
                  </div>
                  <h3 class="sk-dex-name">{bird.name}</h3>
                  <p class="sk-dex-scientific">{bird.scientific}</p>
                  <div class="sk-dex-quick">
                    <span>{bird.habitat.split(',')[0]}</span>
                    <span>{bird.location.split(',')[0]}</span>
                    <span>{bird.sightings}x seen</span>
                  </div>
                  <div class="sk-dex-flip-hint">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                  </div>
                </div>
                <div class="sk-dex-back">
                  <div class="sk-dex-number">Lifer #{String(bird.id).padStart(3, '0')}</div>
                  <h3 class="sk-dex-name">{bird.name}</h3>
                  <div class="sk-dex-details">
                    <div class="sk-dex-row"><span class="sk-dex-label">Habitat</span><span>{bird.habitat}</span></div>
                    <div class="sk-dex-row"><span class="sk-dex-label">Diet</span><span>{bird.diet}</span></div>
                    <div class="sk-dex-row"><span class="sk-dex-label">Wingspan</span><span>{bird.wingspan}</span></div>
                    <div class="sk-dex-row"><span class="sk-dex-label">Weight</span><span>{bird.weight}</span></div>
                    <div class="sk-dex-row"><span class="sk-dex-label">Status</span><span class={bird.status === 'Vulnerable' ? 'sk-dex-warn' : ''}>{bird.status}</span></div>
                    <div class="sk-dex-row"><span class="sk-dex-label">First Seen</span><span>{new Date(bird.firstSeen + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span></div>
                    <div class="sk-dex-row"><span class="sk-dex-label">Location</span><span>{bird.location}</span></div>
                    <div class="sk-dex-row"><span class="sk-dex-label">Sightings</span><span>{bird.sightings}</span></div>
                  </div>
                  <div class="sk-dex-flip-hint">
                    <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
                  </div>
                </div>
              </div>
            </div>
          ))}
          </div>
        </div>
        <button class="sk-dex-arrow sk-dex-arrow-right" id="dex-right" aria-label="Scroll right">
          <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section id="stats" class="sk-section">
    <div class="sk-container">
      <h2 class="sk-section-title sk-anim">By the Numbers</h2>
      <p class="sk-section-sub sk-anim">A birder's journey in data</p>
      <div class="sk-stats-grid">
        {stats.map((stat, i) => (
          <div class={`sk-stat-card sk-anim${stat.featured ? ' sk-stat-featured' : ''}`}>
            <div class="sk-stat-icon">
              <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="1.5">
                <Fragment set:html={iconPaths[i]} />
              </svg>
            </div>
            <div class="sk-stat-num" data-target={stat.value}>0</div>
            <div class="sk-stat-label">{stat.label}</div>
            <div class="sk-stat-sub">{stat.sub}</div>
          </div>
        ))}
      </div>

      <div class="sk-signature sk-anim">
        <div class="sk-signature-label">{signatureStat.label}</div>
        <div class="sk-signature-value">{signatureStat.value}</div>
        <div class="sk-signature-detail">{signatureStat.detail}</div>
        <p class="sk-signature-note">{signatureStat.note}</p>
      </div>
      <div class="sk-recent sk-anim">
        <h3>Recent Sightings</h3>
        {recentSightings.map(s => (
          <div class="sk-sighting">
            <div>
              <div class="sk-sighting-species">{s.species}</div>
              <div class="sk-sighting-loc">{s.location}</div>
            </div>
            <div class="sk-sighting-date">
              {new Date(s.date + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MAP -->
  <section id="map" class="sk-section">
    <div class="sk-container">
      <h2 class="sk-section-title sk-anim">Where I've Been</h2>
      <p class="sk-section-sub sk-anim">5 states explored and counting</p>

      <div class="sk-map-chips sk-anim">
        <button class="sk-chip active" data-metric="visits">Visits</button>
        <button class="sk-chip" data-metric="species">Species</button>
        <button class="sk-chip" data-metric="photos">Photos</button>
      </div>

      <div class="sk-map-wrap sk-anim">
        <div class="sk-svg-container" id="sk-svg-container">
          <div class="sk-map-loading">Loading map...</div>
        </div>
        <div class="sk-map-legend">
          <span class="sk-legend-min">0</span>
          <div class="sk-legend-gradient"></div>
          <span class="sk-legend-max">45</span>
        </div>
      </div>

      <div class="sk-state-detail" id="sk-state-detail" style="display:none">
        <button class="sk-detail-close" id="sk-detail-close" aria-label="Close detail">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
          </svg>
        </button>
        <h3 class="sk-detail-name"></h3>
        <div class="sk-detail-grid">
          <div class="sk-detail-item"><span class="sk-detail-val" id="sd-visits">--</span><span class="sk-detail-label">Visits</span></div>
          <div class="sk-detail-item"><span class="sk-detail-val" id="sd-species">--</span><span class="sk-detail-label">Species</span></div>
          <div class="sk-detail-item"><span class="sk-detail-val" id="sd-photos">--</span><span class="sk-detail-label">Photos</span></div>
        </div>
        <p class="sk-detail-top">Top species: <strong class="sk-detail-top-name"></strong></p>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="sk-footer">
    <div class="sk-container">
      <p class="sk-footer-tag">Built with patience, long lenses, and early mornings.</p>
      <p class="sk-footer-copy">&copy; 2026 Shakshuka Photography. All rights reserved.</p>
    </div>
  </footer>

  <!-- LIGHTBOX -->
  <div class="sk-lightbox" id="sk-lightbox" role="dialog" aria-label="Image viewer">
    <button class="sk-lb-close" aria-label="Close">
      <svg viewBox="0 0 24 24" width="28" height="28" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
    <button class="sk-lb-nav sk-lb-prev" aria-label="Previous">
      <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="15 18 9 12 15 6"/>
      </svg>
    </button>
    <button class="sk-lb-nav sk-lb-next" aria-label="Next">
      <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="9 18 15 12 9 6"/>
      </svg>
    </button>
    <div class="sk-lb-body">
      <img class="sk-lb-img" src="" alt="" />
      <div class="sk-lb-info">
        <h3 class="sk-lb-title"></h3>
        <p class="sk-lb-species"></p>
        <p class="sk-lb-meta"></p>
        <a class="sk-lb-buy" href="#">Inquire to Purchase</a>
      </div>
    </div>
  </div>

  <!-- MAP TOOLTIP -->
  <div class="sk-tooltip" id="sk-tooltip">
    <div class="sk-tooltip-name"></div>
    <div class="sk-tooltip-metrics"></div>
    <div class="sk-tooltip-species"></div>
  </div>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  html { scroll-behavior: smooth; scroll-padding-top: 20px; }
  body {
    /* Color tokens — dark mode defaults */
    --sk-bg: #0f1210;
    --sk-bg-surface: #1a1f1c;
    --sk-bg-surface-grad: linear-gradient(160deg, #1a1f1c 0%, #141914 100%);
