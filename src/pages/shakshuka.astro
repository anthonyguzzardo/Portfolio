    --sk-map-stroke: #1a1f1c;
    --sk-lb-bg: rgba(0,0,0,0.96);

    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--sk-bg);
    color: var(--sk-text);
    line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
    transition: background 0.4s ease, color 0.4s ease;
  }

  /* Light mode overrides */
  body.sk-light {
    --sk-bg: #f7f5f0;
    --sk-bg-surface: #ffffff;
    --sk-bg-surface-grad: linear-gradient(160deg, #ffffff 0%, #f8f6f2 100%);
    --sk-bg-surface-grad-alt: linear-gradient(160deg, #fafaf7 0%, #f5f2ed 100%);
    --sk-bg-surface-grad-rare: linear-gradient(160deg, #fdf8f2 0%, #f8f0e4 100%);
    --sk-bg-stat-grad: linear-gradient(160deg, #ffffff 0%, #f8f6f2 100%);
    --sk-bg-sig-grad: linear-gradient(160deg, rgba(196,129,61,0.06) 0%, rgba(255,255,255,0.8) 100%);
    --sk-text: #1a1510;
    --sk-text-muted: #5a5248;
    --sk-text-sub: #4a4235;
    --sk-text-faint: #999;
    --sk-text-faintest: #aaa;
    --sk-green: #4a7a35;
    --sk-green-dark: #3d6a2c;
    --sk-green-hover: #2f5a20;
    --sk-green-border: #8cb875;
    --sk-green-bg: rgba(74,122,53,0.1);
    --sk-green-bg-strong: rgba(74,122,53,0.12);
    --sk-gold: #b8742e;
    --sk-gold-hover: #9c6228;
    --sk-gold-bg: rgba(184,116,46,0.12);
    --sk-gold-border: rgba(184,116,46,0.3);
    --sk-border: #ddd8d0;
    --sk-border-sug: #e5e0d8;
    --sk-nav-scrolled: rgba(247,245,240,0.95);
    --sk-nav-shadow: 0 1px 0 rgba(0,0,0,0.08);
    --sk-hero-overlay: linear-gradient(to bottom, rgba(247,245,240,0.92) 0%, rgba(247,245,240,0.95) 50%, rgba(247,245,240,1) 100%);
    --sk-card-overlay: linear-gradient(to top, rgba(0,0,0,0.85), transparent);
    --sk-glass: rgba(0,0,0,0.08);
    --sk-glass-strong: rgba(0,0,0,0.12);
    --sk-glass-faint: rgba(0,0,0,0.03);
    --sk-glass-border: rgba(0,0,0,0.15);
    --sk-map-stroke: #3a3530;
    --sk-lb-bg: rgba(0,0,0,0.92);
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  button { font: inherit; cursor: pointer; border: none; background: none; color: inherit; }
  h1, h2, h3 { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; line-height: 1.2; }

  .sk-container { max-width: 1200px; margin: 0 auto; padding: 0 2rem; }
  .sk-section { padding: 6rem 0; }
  .sk-section-title { font-size: 2.5rem; margin-bottom: 0.5rem; text-align: center; }
  .sk-section-sub { color: var(--sk-text-muted); font-size: 1.1rem; font-weight: 300; margin-bottom: 3rem; text-align: center; }

  /* NAV — hidden until scrolled past hero */
  .sk-nav {
    position: fixed; top: 0; left: 0; right: 0; z-index: 100;
    padding: 1.25rem 2rem; transition: background 0.3s, box-shadow 0.3s, opacity 0.3s, transform 0.3s;
    opacity: 0; transform: translateY(-100%); pointer-events: none;
  }
  .sk-nav.visible {
    opacity: 1; transform: translateY(0); pointer-events: auto;
  }
  .sk-nav.scrolled { background: var(--sk-nav-scrolled); backdrop-filter: blur(12px); box-shadow: var(--sk-nav-shadow); }
  .sk-nav-inner { max-width: 1200px; margin: 0 auto; display: flex; justify-content: space-between; align-items: center; }
  .sk-nav-right { display: flex; align-items: center; gap: 1.5rem; }
  .sk-nav-logo { font-family: 'Playfair Display', serif; font-size: 1.4rem; font-weight: 700; letter-spacing: 0.5px; }
  .sk-nav-links { display: flex; gap: 2.5rem; list-style: none; }
  .sk-nav-links a {
    font-size: 0.9rem; font-weight: 400; opacity: 0.7; text-transform: uppercase; letter-spacing: 1px;
    position: relative; padding-bottom: 4px;
    transition: opacity 0.3s, color 0.3s;
  }
  .sk-nav-links a::after {
    content: ''; position: absolute; bottom: 0; left: 50%; width: 0; height: 2px;
    background: var(--sk-green); transition: width 0.3s ease, left 0.3s ease;
  }
  .sk-nav-links a:hover { opacity: 1; color: var(--sk-green); }
  .sk-nav-links a:hover::after { width: 100%; left: 0; }
  .sk-nav-links a:active { transform: scale(0.95); }
  .sk-nav-toggle { display: none; }

  /* HERO: The Perch */
  .sk-hero {
    min-height: 100vh; display: flex; align-items: center; justify-content: center;
    text-align: center; position: relative; overflow: hidden;
    background: var(--sk-bg);
  }

  .sk-perch-inner {
    display: flex; flex-direction: column; align-items: center;
    justify-content: center; padding: 0 2rem;
  }

  .sk-wordmark-area {
    position: relative; display: flex; flex-direction: column; align-items: center;
  }

  /* Wordmark */
  .sk-wordmark {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: clamp(3rem, 14vw, 7rem);
    font-weight: 700; margin: 0; letter-spacing: -0.02em;
    line-height: 1; cursor: pointer; position: relative; z-index: 2;
    color: var(--sk-text);
  }

  .sk-wordmark.settled .sk-letter {
    animation: none !important; opacity: 1 !important;
    transform: scale(var(--sk-lens-scale, 1)) !important;
    transition: transform 0.15s ease-out;
  }

  .sk-letter {
    display: inline-block; z-index: 2; position: relative;
    transform-origin: center bottom;
  }

  /* Lens beam — subtle circle overlay following cursor */
  .sk-lens-beam {
    position: fixed; top: 0; left: 0;
    pointer-events: none; z-index: 3;
    opacity: 0; transition: opacity 300ms ease;
  }
  .sk-lens-beam.visible { opacity: 1; }
  .sk-lens-circle {
    position: absolute; border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.08);
    background: radial-gradient(circle, rgba(255,255,255,0.03) 0%, transparent 70%);
  }
  body.sk-light .sk-lens-circle {
    border-color: rgba(0,0,0,0.06);
    background: radial-gradient(circle, rgba(0,0,0,0.02) 0%, transparent 70%);
  }

  /* ============================================
     Combined glide + flutter keyframes
     Each letter uses ONE animation — no transform conflicts.
     Glide is ~55% of duration, flutter is ~45%.
     ============================================ */

  /* Heavy left (S) — big swoop, strong wobble */
  @keyframes perch-left-heavy {
    0%   { opacity: 0; transform: translate(-120px, -100vh); }
    5%   { opacity: 1; }
    33%  { transform: translate(-30px, -20px); }
    44%  { transform: translate(8px, 5px); }
    55%  { transform: translate(0, 0) rotate(0deg); }
    62%  { transform: rotate(8deg); }
    70%  { transform: rotate(-6deg); }
    78%  { transform: rotate(4deg); }
    85%  { transform: rotate(-2.5deg); }
    91%  { transform: rotate(1.5deg); }
    96%  { transform: rotate(-0.5deg); }
    100% { opacity: 1; transform: rotate(0deg); }
  }
  /* Heavy right (k) */
  @keyframes perch-right-heavy {
    0%   { opacity: 0; transform: translate(120px, -100vh); }
    5%   { opacity: 1; }
    33%  { transform: translate(30px, -20px); }
    44%  { transform: translate(-8px, 5px); }
    55%  { transform: translate(0, 0) rotate(0deg); }
    62%  { transform: rotate(8deg); }
    70%  { transform: rotate(-6deg); }
    78%  { transform: rotate(4deg); }
    85%  { transform: rotate(-2.5deg); }
    91%  { transform: rotate(1.5deg); }
    96%  { transform: rotate(-0.5deg); }
    100% { opacity: 1; transform: rotate(0deg); }
  }
  /* Medium left (s, u) */
  @keyframes perch-left-medium {
    0%   { opacity: 0; transform: translate(-100px, -100vh); }
    5%   { opacity: 1; }
    33%  { transform: translate(-25px, -18px); }
    44%  { transform: translate(6px, 4px); }
    55%  { transform: translate(0, 0) rotate(0deg); }
    65%  { transform: rotate(5deg); }
    75%  { transform: rotate(-3.5deg); }
    85%  { transform: rotate(2deg); }
    93%  { transform: rotate(-1deg); }
    100% { opacity: 1; transform: rotate(0deg); }
  }
  /* Medium right (unused but symmetric) */
  @keyframes perch-right-medium {
    0%   { opacity: 0; transform: translate(100px, -100vh); }
    5%   { opacity: 1; }
    33%  { transform: translate(25px, -18px); }
    44%  { transform: translate(-6px, 4px); }
    55%  { transform: translate(0, 0) rotate(0deg); }
    65%  { transform: rotate(5deg); }
    75%  { transform: rotate(-3.5deg); }
    85%  { transform: rotate(2deg); }
    93%  { transform: rotate(-1deg); }
    100% { opacity: 1; transform: rotate(0deg); }
  }
  /* Light left (a) — gentle arc, quick settle */
  @keyframes perch-left-light {
    0%   { opacity: 0; transform: translate(-80px, -100vh); }
    5%   { opacity: 1; }
    33%  { transform: translate(-20px, -15px); }
    44%  { transform: translate(5px, 3px); }
    55%  { transform: translate(0, 0) rotate(0deg); }
    68%  { transform: rotate(3deg); }
    80%  { transform: rotate(-2deg); }
    90%  { transform: rotate(1deg); }
    100% { opacity: 1; transform: rotate(0deg); }
  }
  /* Light right (h) */
  @keyframes perch-right-light {
    0%   { opacity: 0; transform: translate(80px, -100vh); }
    5%   { opacity: 1; }
    33%  { transform: translate(20px, -15px); }
    44%  { transform: translate(-5px, 3px); }
    55%  { transform: translate(0, 0) rotate(0deg); }
    68%  { transform: rotate(3deg); }
    80%  { transform: rotate(-2deg); }
    90%  { transform: rotate(1deg); }
    100% { opacity: 1; transform: rotate(0deg); }
  }

  /* ============================================
     Per-letter — one animation each, staggered delays
     Total duration 1.1s each
     ============================================ */
  .sk-letter-S {
    color: var(--sk-green); opacity: 0;
    animation: perch-left-heavy 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 0.2s;
  }
  .sk-letter-h1 {
    opacity: 0;
    animation: perch-right-light 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 0.35s;
  }
  .sk-letter-a1 {
    opacity: 0;
    animation: perch-left-light 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 0.5s;
  }
  .sk-letter-k1 {
    color: var(--sk-green); opacity: 0;
    animation: perch-right-heavy 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 0.65s;
  }
  .sk-letter-s {
    opacity: 0;
    animation: perch-left-medium 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 0.8s;
  }
  .sk-letter-h2 {
    opacity: 0;
    animation: perch-right-light 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 0.95s;
  }
  .sk-letter-u {
    opacity: 0;
    animation: perch-left-medium 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 1.1s;
  }
  .sk-letter-k2 {
    color: var(--sk-green); opacity: 0;
    animation: perch-right-heavy 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 1.25s;
  }
  .sk-letter-a2 {
    opacity: 0;
    animation: perch-left-light 1.1s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards 1.4s;
  }

  /* Hero theme toggle — top-right corner */
  .sk-perch-mode {
    position: absolute; top: 1.5rem; right: 1.5rem; z-index: 10;
    display: flex; align-items: center; justify-content: center;
    width: 40px; height: 40px; border-radius: 50%;
    border: 1px solid var(--sk-border); background: transparent;
    color: var(--sk-text-muted); cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
    opacity: 0; animation: sk-fade-up 0.5s ease forwards 3.1s;
  }
  .sk-perch-mode:hover {
    color: var(--sk-green); border-color: var(--sk-green-dark);
    background: var(--sk-green-bg);
  }
  .sk-perch-mode svg { width: 18px; height: 18px; }
  .sk-perch-mode .sk-icon-moon { display: none; }
  body.sk-light .sk-perch-mode .sk-icon-sun { display: none; }
  body.sk-light .sk-perch-mode .sk-icon-moon { display: block; }

  /* Tagline + Perch Nav fade-up */
  @keyframes sk-fade-up {
    0%   { opacity: 0; transform: translateY(16px); }
    100% { opacity: 1; transform: translateY(0); }
  }
  .sk-perch-tagline {
    font-family: 'Playfair Display', serif; font-style: italic;
    font-size: 1.2rem; color: var(--sk-text-sub);
    margin-top: 1.5rem; letter-spacing: 0.5px;
    opacity: 0; animation: sk-fade-up 0.5s ease forwards 2.8s;
  }
  .sk-perch-nav {
    display: flex; gap: 2.5rem; margin-top: 2.5rem;
    opacity: 0; animation: sk-fade-up 0.5s ease forwards 3.1s;
  }
  .sk-perch-nav a {
    font-size: 0.85rem; font-weight: 400; text-transform: uppercase;
    letter-spacing: 1.5px; color: var(--sk-text-muted);
    position: relative; padding-bottom: 4px;
    transition: color 0.3s;
  }
  .sk-perch-nav a::after {
    content: ''; position: absolute; bottom: 0; left: 50%; width: 0; height: 2px;
    background: var(--sk-green); transition: width 0.3s ease, left 0.3s ease;
  }
  .sk-perch-nav a:hover { color: var(--sk-green); }
  .sk-perch-nav a:hover::after { width: 100%; left: 0; }

  /* ============================================
     Mobile — scaled-down combined keyframes
     ============================================ */
  @media (max-width: 639px) {
    .sk-perch-nav { gap: 1.25rem; flex-wrap: wrap; justify-content: center; }
    .sk-perch-nav a { font-size: 0.7rem; letter-spacing: 1px; }

    @keyframes perch-left-heavy-sm {
      0%   { opacity: 0; transform: translate(-50px, -100vh); }
      5%   { opacity: 1; }
      33%  { transform: translate(-12px, -10px); }
      44%  { transform: translate(4px, 2px); }
      55%  { transform: translate(0, 0) rotate(0deg); }
      62%  { transform: rotate(4deg); }
      72%  { transform: rotate(-3deg); }
      82%  { transform: rotate(1.5deg); }
      92%  { transform: rotate(-0.5deg); }
      100% { opacity: 1; transform: rotate(0deg); }
    }
    @keyframes perch-right-heavy-sm {
      0%   { opacity: 0; transform: translate(50px, -100vh); }
      5%   { opacity: 1; }
      33%  { transform: translate(12px, -10px); }
      44%  { transform: translate(-4px, 2px); }
      55%  { transform: translate(0, 0) rotate(0deg); }
      62%  { transform: rotate(4deg); }
      72%  { transform: rotate(-3deg); }
      82%  { transform: rotate(1.5deg); }
      92%  { transform: rotate(-0.5deg); }
      100% { opacity: 1; transform: rotate(0deg); }
    }
    @keyframes perch-left-medium-sm {
      0%   { opacity: 0; transform: translate(-40px, -100vh); }
      5%   { opacity: 1; }
      33%  { transform: translate(-10px, -8px); }
      44%  { transform: translate(3px, 2px); }
      55%  { transform: translate(0, 0) rotate(0deg); }
      68%  { transform: rotate(3deg); }
      80%  { transform: rotate(-2deg); }
      90%  { transform: rotate(1deg); }
      100% { opacity: 1; transform: rotate(0deg); }
    }
    @keyframes perch-left-light-sm {
      0%   { opacity: 0; transform: translate(-30px, -100vh); }
      5%   { opacity: 1; }
      33%  { transform: translate(-8px, -6px); }
      44%  { transform: translate(2px, 1px); }
      55%  { transform: translate(0, 0) rotate(0deg); }
      72%  { transform: rotate(2deg); }
      85%  { transform: rotate(-1deg); }
      100% { opacity: 1; transform: rotate(0deg); }
    }
    @keyframes perch-right-light-sm {
      0%   { opacity: 0; transform: translate(30px, -100vh); }
      5%   { opacity: 1; }
      33%  { transform: translate(8px, -6px); }
      44%  { transform: translate(-2px, 1px); }
      55%  { transform: translate(0, 0) rotate(0deg); }
      72%  { transform: rotate(2deg); }
      85%  { transform: rotate(-1deg); }
      100% { opacity: 1; transform: rotate(0deg); }
    }
    .sk-letter-S { animation-name: perch-left-heavy-sm; }
    .sk-letter-h1 { animation-name: perch-right-light-sm; }
    .sk-letter-a1 { animation-name: perch-left-light-sm; }
    .sk-letter-k1 { animation-name: perch-right-heavy-sm; }
    .sk-letter-s { animation-name: perch-left-medium-sm; }
    .sk-letter-h2 { animation-name: perch-right-light-sm; }
    .sk-letter-u { animation-name: perch-left-medium-sm; }
    .sk-letter-k2 { animation-name: perch-right-heavy-sm; }
    .sk-letter-a2 { animation-name: perch-left-light-sm; }
  }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    .sk-letter-S, .sk-letter-h1, .sk-letter-a1, .sk-letter-k1,
    .sk-letter-s, .sk-letter-h2, .sk-letter-u, .sk-letter-k2, .sk-letter-a2 {
      animation: none !important; opacity: 1 !important; transform: none !important;
    }
    .sk-perch-tagline, .sk-perch-nav, .sk-perch-mode { animation: none; opacity: 1; }
    .sk-lens-beam { display: none !important; }
  }

  .sk-btn-primary {
    padding: 0.85rem 2.25rem; background: var(--sk-green-dark); color: white; border-radius: 4px;
    font-weight: 500; font-size: 0.9rem; letter-spacing: 0.5px; transition: background 0.2s, transform 0.2s;
  }
  .sk-btn-primary:hover { background: var(--sk-green-hover); transform: translateY(-1px); }
  .sk-btn-outline {
    padding: 0.85rem 2.25rem; border: 1px solid var(--sk-glass-strong); border-radius: 4px;
    font-weight: 500; font-size: 0.9rem; letter-spacing: 0.5px; transition: border-color 0.2s, color 0.2s;
  }
  .sk-btn-outline:hover { border-color: var(--sk-green-dark); color: var(--sk-green); }

  /* GALLERY */
  .sk-filters { display: flex; gap: 0.75rem; justify-content: center; margin-bottom: 2.5rem; flex-wrap: wrap; }
  .sk-filter-btn {
    padding: 0.5rem 1.5rem; border-radius: 100px; border: 1px solid var(--sk-border);
    font-size: 0.85rem; text-transform: capitalize; transition: all 0.2s; background: transparent;
  }
  .sk-filter-btn.active, .sk-filter-btn:hover { background: var(--sk-green-dark); border-color: var(--sk-green-dark); color: white; }

  .sk-gallery-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: 1.25rem; }
  .sk-card {
    position: relative; border-radius: 8px; overflow: hidden; cursor: pointer;
    aspect-ratio: 3/2; background: var(--sk-bg-surface);
  }
  .sk-card img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.5s ease; }
  .sk-card:hover img { transform: scale(1.05); }
  .sk-card-overlay {
    position: absolute; bottom: 0; left: 0; right: 0; padding: 3rem 1.25rem 1.25rem;
    background: var(--sk-card-overlay);
    opacity: 0; transition: opacity 0.3s;
  }
  .sk-card:hover .sk-card-overlay { opacity: 1; }
  .sk-card-title { font-family: 'Playfair Display', serif; font-size: 1.05rem; margin-bottom: 0.2rem; color: #e8e4dc; }
  .sk-card-loc { font-size: 0.8rem; color: #8a8474; }
  .sk-badge {
    position: absolute; top: 1rem; right: 1rem; padding: 0.3rem 0.75rem;
    background: var(--sk-green-dark); border-radius: 100px; font-size: 0.65rem;
    font-weight: 600; text-transform: uppercase; letter-spacing: 1px;
  }
  .sk-play-icon {
    position: absolute; top: 50%; left: 50%; transform: translate(-50%,-50%);
    width: 56px; height: 56px; background: rgba(255,255,255,0.15); border-radius: 50%;
    display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px);
    pointer-events: none; border: 2px solid rgba(255,255,255,0.3);
  }

  /* FIELD GUIDE / DEX */
  #field-guide .sk-section-sub { margin-bottom: 1.25rem; }
  .sk-view-all {
    display: inline-block; margin-left: 0.25rem;
    font-size: 0.85rem; color: var(--sk-green-dark); font-weight: 500;
    border-bottom: 1px solid transparent; transition: border-color 0.2s, color 0.2s;
  }
  .sk-view-all:hover { color: var(--sk-green); border-color: var(--sk-green); }

  .sk-dex-search-wrap { display: flex; justify-content: center; margin-bottom: 1.25rem; position: relative; z-index: 10; }
  .sk-dex-search-box { position: relative; width: 100%; max-width: 360px; }
  .sk-dex-search-icon {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    color: var(--sk-green-dark); pointer-events: none;
  }
  .sk-dex-search {
    width: 100%; padding: 0.6rem 0.75rem 0.6rem 2.25rem;
    background: var(--sk-bg-surface); border: 1px solid var(--sk-border); border-radius: 8px;
    color: var(--sk-text); font-family: 'Inter', sans-serif; font-size: 0.85rem;
    outline: none; transition: border-color 0.2s;
  }
  .sk-dex-search::placeholder { color: var(--sk-text-faint); }
  .sk-dex-search:focus { border-color: var(--sk-green-dark); }
  .sk-dex-suggestions {
    display: none; position: absolute; top: calc(100% + 4px); left: 0; right: 0;
    background: var(--sk-bg-surface); border: 1px solid var(--sk-border); border-radius: 8px;
    max-height: 240px; overflow-y: auto; z-index: 50;
  }
  .sk-dex-suggestions.open { display: block; }
  .sk-dex-sug-item {
    padding: 0.5rem 0.75rem; font-size: 0.8rem; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    transition: background 0.15s;
  }
  .sk-dex-sug-item:hover, .sk-dex-sug-item.active { background: var(--sk-green-bg); }
  .sk-dex-sug-item + .sk-dex-sug-item { border-top: 1px solid var(--sk-border-sug); }
  .sk-dex-sug-name { color: var(--sk-text); }
  .sk-dex-sug-sci { color: var(--sk-green); font-style: italic; font-size: 0.7rem; }
  .sk-dex-sug-tag {
    font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px;
    padding: 0.1rem 0.4rem; border-radius: 100px; flex-shrink: 0; margin-left: 0.5rem;
  }
  .sk-dex-sug-tag.spotted { color: var(--sk-green-dark); background: var(--sk-green-bg-strong); }
  .sk-dex-sug-tag.unspotted { color: var(--sk-text-faint); background: var(--sk-glass-faint); }

  .sk-dex-shelf {
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    position: relative;
  }
  .sk-dex-track {
    overflow: hidden; width: 250px; flex-shrink: 0;
  }
  .sk-dex-track-inner {
    display: flex; gap: 1.25rem;
    transition: transform 0.4s ease;
  }
  .sk-dex-card {
    min-width: 250px; max-width: 250px; height: 420px;
    perspective: 900px; flex-shrink: 0;
  }
  .sk-dex-arrow {
    width: 44px; height: 44px; border-radius: 50%; border: 1px solid var(--sk-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--sk-text-muted); transition: all 0.2s; background: var(--sk-bg-surface);
    flex-shrink: 0; z-index: 2;
  }
  .sk-dex-arrow:hover { border-color: var(--sk-green-dark); color: var(--sk-green); background: var(--sk-green-bg); }
  .sk-dex-arrow.disabled { opacity: 0.25; pointer-events: none; }
  .sk-dex-card-inner {
    width: 100%; height: 100%; position: relative;
    transition: transform 0.6s ease; transform-style: preserve-3d; cursor: pointer;
  }
  .sk-dex-card.flipped .sk-dex-card-inner { transform: rotateY(180deg); }
  .sk-dex-front, .sk-dex-back {
    position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden;
    transform-style: flat; -webkit-transform-style: flat;
    border-radius: 14px; padding: 1.25rem; display: flex; flex-direction: column;
    border: 2px solid var(--sk-border); overflow: hidden;
  }
  .sk-dex-front { transition: visibility 0s 0.3s; }
  .sk-dex-card.flipped .sk-dex-front { visibility: hidden; }
  .sk-dex-back { transform: rotateY(180deg); visibility: hidden; transition: visibility 0s 0.3s; }
  .sk-dex-card.flipped .sk-dex-back { visibility: visible; }

  /* Rarity card tints */
  .sk-dex-card[data-rarity="common"] .sk-dex-front,
  .sk-dex-card[data-rarity="common"] .sk-dex-back {
    background: var(--sk-bg-surface-grad);
    border-color: var(--sk-green-border);
  }
  .sk-dex-card[data-rarity="uncommon"] .sk-dex-front,
  .sk-dex-card[data-rarity="uncommon"] .sk-dex-back {
    background: var(--sk-bg-surface-grad-alt);
    border-color: var(--sk-green-dark);
    box-shadow: 0 0 25px var(--sk-green-bg), inset 0 1px 0 rgba(91,140,62,0.08);
  }
  .sk-dex-card[data-rarity="rare"] .sk-dex-front,
  .sk-dex-card[data-rarity="rare"] .sk-dex-back {
    background: var(--sk-bg-surface-grad-rare);
    border-color: var(--sk-gold);
    box-shadow: 0 0 30px var(--sk-gold-bg), inset 0 1px 0 rgba(196,129,61,0.1);
  }

  .sk-dex-header {
    display: flex; justify-content: space-between; align-items: center;
    margin-bottom: 0.25rem;
  }
  .sk-dex-number {
    font-family: 'Inter', monospace; font-size: 0.7rem; font-weight: 600;
    color: var(--sk-green-dark); letter-spacing: 0.5px;
  }
  .sk-dex-of { color: var(--sk-text-faint); font-weight: 400; }
  .sk-dex-rarity {
    font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px;
    padding: 0.15rem 0.55rem; border-radius: 100px;
  }
  [data-rarity="common"] .sk-dex-rarity { color: var(--sk-green-dark); background: var(--sk-green-bg); }
  [data-rarity="uncommon"] .sk-dex-rarity { color: var(--sk-green); background: var(--sk-green-bg-strong); }
  [data-rarity="rare"] .sk-dex-rarity { color: var(--sk-gold); background: var(--sk-gold-bg); }

  .sk-dex-img-wrap {
    flex: 1; margin: 0.5rem 0; border-radius: 8px; overflow: hidden;
    background: var(--sk-bg); min-height: 0;
  }
  .sk-dex-img-wrap img {
    width: 100%; height: 100%; object-fit: cover;
    transition: transform 0.4s ease;
  }
  .sk-dex-card-inner:hover .sk-dex-img-wrap img { transform: scale(1.05); }

  .sk-dex-name {
    font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 700;
    margin-bottom: 0.1rem;
  }
  .sk-dex-scientific {
    font-size: 0.75rem; color: var(--sk-green); font-style: italic; margin-bottom: 0.4rem;
  }
  .sk-dex-quick {
    display: flex; justify-content: space-between;
    font-size: 0.7rem; color: var(--sk-text-sub); letter-spacing: 0.2px;
  }
  .sk-dex-flip-hint {
    text-align: center; margin-top: auto; padding-top: 0.4rem;
    color: var(--sk-text-faintest); transition: color 0.2s;
  }
  .sk-dex-card-inner:hover .sk-dex-flip-hint { color: var(--sk-green); }

  /* Back face */
  .sk-dex-back .sk-dex-number { margin-bottom: 0.15rem; }
  .sk-dex-back .sk-dex-name { margin-bottom: 0.75rem; }
  .sk-dex-details { flex: 1; display: flex; flex-direction: column; gap: 0.45rem; }
  .sk-dex-row {
    display: flex; justify-content: space-between; align-items: baseline;
    font-size: 0.78rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--sk-border);
  }
  .sk-dex-row:last-child { border-bottom: none; }
  .sk-dex-label { color: var(--sk-text-muted); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px; }
  .sk-dex-warn { color: var(--sk-gold); font-weight: 600; }

  @media (max-width: 480px) {
    .sk-dex-card { min-width: 220px; max-width: 220px; height: 390px; }
    .sk-dex-track { width: 220px; }
    .sk-dex-arrow { width: 36px; height: 36px; }
    .sk-dex-name { font-size: 1.1rem; }
  }

  /* STATS */
  .sk-stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2.5rem; }
  .sk-stat-card {
    background: var(--sk-bg-stat-grad);
    border: 1px solid var(--sk-border); border-radius: 12px;
    padding: 1.5rem 1.25rem; text-align: center;
    transition: border-color 0.3s, transform 0.3s, box-shadow 0.3s;
  }
  .sk-stat-card:hover { border-color: var(--sk-green-border); transform: translateY(-2px); box-shadow: 0 4px 20px rgba(0,0,0,0.15); }
  .sk-stat-featured { grid-column: span 2; }
  .sk-stat-featured .sk-stat-num { font-size: 3.5rem; }
  .sk-stat-icon { color: var(--sk-green-dark); margin-bottom: 0.6rem; }
  .sk-stat-num { font-family: 'Playfair Display', serif; font-size: 2.5rem; font-weight: 700; margin-bottom: 0.15rem; }
  .sk-stat-label { color: var(--sk-text-sub); font-size: 0.8rem; font-weight: 500; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.35rem; }
  .sk-stat-sub { font-size: 0.72rem; color: var(--sk-green-dark); font-weight: 400; letter-spacing: 0.3px; }

  .sk-signature {
    max-width: 600px; margin: 0 auto 3.5rem; text-align: center;
    padding: 2rem; border-radius: 12px; position: relative;
    background: var(--sk-bg-sig-grad);
    border: 1px solid var(--sk-gold-border);
  }
  .sk-signature-label {
    font-size: 0.7rem; text-transform: uppercase; letter-spacing: 2px;
    color: var(--sk-gold); font-weight: 600; margin-bottom: 0.5rem;
  }
  .sk-signature-value {
    font-family: 'Playfair Display', serif; font-size: 2.2rem; font-weight: 700;
    color: var(--sk-text); margin-bottom: 0.35rem;
  }
  .sk-signature-detail { font-size: 0.85rem; color: var(--sk-text-sub); margin-bottom: 0.75rem; }
  .sk-signature-note {
    font-size: 0.8rem; color: var(--sk-text-muted); font-style: italic; line-height: 1.6;
    max-width: 420px; margin: 0 auto;
  }

  .sk-recent { max-width: 700px; margin: 0 auto; }
  .sk-recent h3 { font-size: 1.5rem; margin-bottom: 1.5rem; text-align: center; }
  .sk-sighting {
    display: flex; justify-content: space-between; align-items: center;
    padding: 1.1rem 0; border-bottom: 1px solid var(--sk-border);
  }
  .sk-sighting:last-child { border-bottom: none; }
  .sk-sighting-species { font-weight: 500; margin-bottom: 0.15rem; }
  .sk-sighting-loc { color: var(--sk-text-muted); font-size: 0.85rem; }
  .sk-sighting-date { color: var(--sk-green-dark); font-size: 0.85rem; white-space: nowrap; font-weight: 500; }

  /* MAP */
  .sk-map-chips { display: flex; gap: 0.6rem; justify-content: center; margin-bottom: 1.5rem; }
  .sk-chip {
    padding: 0.45rem 1.25rem; border-radius: 100px; border: 1px solid var(--sk-border);
    font-size: 0.8rem; font-weight: 500; transition: all 0.2s; background: transparent; cursor: pointer;
  }
  .sk-chip.active { background: var(--sk-green-bg-strong); border-color: var(--sk-green-dark); color: var(--sk-green); }
  .sk-chip:hover { border-color: var(--sk-green-dark); }

  .sk-map-wrap { max-width: 800px; margin: 0 auto; }
  .sk-svg-container { position: relative; width: 100%; }
  .sk-svg-container svg { width: 100%; height: auto; display: block; }
  .sk-svg-wrap { border-radius: 8px; overflow: hidden; background: var(--sk-glass-faint); }
  .sk-svg-wrap [data-state] {
    transform-box: fill-box;
    transform-origin: center;
    cursor: pointer;
    transition: fill 0.2s ease, stroke 0.2s ease, transform 0.25s ease, filter 0.25s ease;
  }
  .sk-map-loading { text-align: center; padding: 4rem 0; color: var(--sk-text-faint); font-size: 0.9rem; }

  .sk-map-legend {
    display: flex; align-items: center; justify-content: center; gap: 0.75rem;
    margin-top: 1.25rem; font-size: 0.75rem; color: var(--sk-text-muted);
  }
  .sk-legend-gradient {
    width: 200px; height: 10px; border-radius: 5px;
    background: linear-gradient(to right, rgba(91,140,62,0.08), rgba(91,140,62,0.9));
  }

  .sk-state-detail {
    max-width: 500px; margin: 2rem auto 0; background: var(--sk-bg-surface); border: 1px solid var(--sk-border);
    border-radius: 12px; padding: 1.75rem 2rem; position: relative;
  }
  .sk-detail-close { position: absolute; top: 1rem; right: 1rem; opacity: 0.5; transition: opacity 0.2s; }
  .sk-detail-close:hover { opacity: 1; }
  .sk-detail-name { font-size: 1.4rem; margin-bottom: 1.25rem; }
  .sk-detail-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 1.25rem; }
  .sk-detail-item { text-align: center; }
  .sk-detail-val { display: block; font-family: 'Playfair Display', serif; font-size: 1.75rem; font-weight: 700; color: var(--sk-green); }
  .sk-detail-label { font-size: 0.75rem; color: var(--sk-text-muted); text-transform: uppercase; letter-spacing: 1px; }
  .sk-detail-top { font-size: 0.9rem; color: var(--sk-text-muted); }
  .sk-detail-top strong { color: var(--sk-text); font-style: italic; }

  .sk-tooltip {
    position: fixed; padding: 0.85rem 1.1rem; background: var(--sk-bg-surface);
    border: 1px solid var(--sk-border); border-left: 3px solid var(--sk-green-dark);
    border-radius: 4px; font-size: 0.85rem; pointer-events: none; z-index: 200;
    opacity: 0; white-space: nowrap;
  }
  .sk-tooltip.visible { opacity: 1; animation: sk-tooltip-in 0.15s ease forwards; }
  @keyframes sk-tooltip-in { from { opacity: 0; transform: translateY(4px); } to { opacity: 1; transform: translateY(0); } }
  .sk-tooltip-name { font-weight: 700; font-size: 0.95rem; margin-bottom: 0.35rem; }
  .sk-tooltip-metrics { color: var(--sk-green); font-size: 0.8rem; margin-bottom: 0.15rem; }
  .sk-tooltip-species { color: var(--sk-text-muted); font-size: 0.75rem; font-style: italic; }

  /* LIGHTBOX */
  .sk-lightbox {
    position: fixed; inset: 0; z-index: 1000; background: var(--sk-lb-bg);
    display: flex; align-items: center; justify-content: center;
    opacity: 0; pointer-events: none; transition: opacity 0.3s;
  }
  .sk-lightbox.open { opacity: 1; pointer-events: auto; }
  .sk-lb-close { position: absolute; top: 1.5rem; right: 1.5rem; opacity: 0.6; transition: opacity 0.2s; z-index: 1001; }
  .sk-lb-close:hover { opacity: 1; }
  .sk-lb-body { max-width: 90vw; max-height: 90vh; display: flex; flex-direction: column; align-items: center; }
  .sk-lb-img { max-width: 100%; max-height: 70vh; object-fit: contain; border-radius: 4px; }
  .sk-lb-info { margin-top: 1.5rem; text-align: center; }
  .sk-lb-title { font-size: 1.5rem; margin-bottom: 0.25rem; }
  .sk-lb-species { color: var(--sk-green); font-style: italic; font-size: 0.9rem; margin-bottom: 0.25rem; }
  .sk-lb-meta { color: var(--sk-text-muted); font-size: 0.9rem; margin-bottom: 1.25rem; }
  .sk-lb-buy {
    display: inline-block; padding: 0.65rem 1.75rem; background: var(--sk-gold); color: white;
    border-radius: 4px; font-weight: 500; font-size: 0.9rem; transition: background 0.2s;
  }
  .sk-lb-buy:hover { background: var(--sk-gold-hover); }
  .sk-lb-nav {
    position: absolute; top: 50%; transform: translateY(-50%); opacity: 0.4;
    transition: opacity 0.2s; padding: 1rem;
  }
  .sk-lb-nav:hover { opacity: 1; }
  .sk-lb-prev { left: 1rem; }
  .sk-lb-next { right: 1rem; }

  /* FOOTER */
  .sk-footer { padding: 3rem 0; border-top: 1px solid var(--sk-border); text-align: center; }
  .sk-footer-tag { font-family: 'Playfair Display', serif; font-size: 1.05rem; color: var(--sk-text-muted); margin-bottom: 0.5rem; font-style: italic; }
  .sk-footer-copy { font-size: 0.8rem; color: var(--sk-text-faintest); }

  /* LIGHT/DARK TOGGLE */
  .sk-mode-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid var(--sk-border); background: transparent;
    color: var(--sk-text-muted); cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .sk-mode-toggle:hover { color: var(--sk-green); border-color: var(--sk-green-dark); background: var(--sk-green-bg); }
  .sk-mode-toggle svg { width: 18px; height: 18px; }
  .sk-mode-toggle .sk-icon-moon { display: none; }
  body.sk-light .sk-mode-toggle .sk-icon-sun { display: none; }
  body.sk-light .sk-mode-toggle .sk-icon-moon { display: block; }

  /* Light mode overrides for nav + map */
  body.sk-light .sk-nav-links a { color: var(--sk-text); }
  body.sk-light .sk-btn-outline {
    border-color: rgba(0,0,0,0.25);
    color: #2a2520;
  }
  body.sk-light .sk-svg-wrap .borders { stroke: #3a3530 !important; }
  body.sk-light .sk-svg-wrap .separator1 { stroke: #6a6560 !important; }
  body.sk-light .sk-svg-wrap .state { fill: #e8e4de; }

  /* ANIMATIONS */
  .sk-anim { opacity: 0; transform: translateY(24px); transition: opacity 0.7s ease, transform 0.7s ease; }
  .sk-anim.visible { opacity: 1; transform: translateY(0); }

  /* RESPONSIVE */
  @media (max-width: 1024px) {
    .sk-stats-grid { grid-template-columns: repeat(2, 1fr); }
    .sk-gallery-grid { grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); }
  }
  @media (max-width: 768px) {
    .sk-section-title { font-size: 2rem; }
    .sk-nav-links { display: none; flex-direction: column; position: absolute; top: 100%; left: 0; right: 0; background: var(--sk-nav-scrolled); padding: 1.5rem 2rem; gap: 1.25rem; backdrop-filter: blur(12px); }
    .sk-nav-links.open { display: flex; }
    .sk-nav-toggle { display: block; }
    .sk-sighting { flex-direction: column; align-items: flex-start; gap: 0.35rem; }
    .sk-section { padding: 4rem 0; }
    .sk-detail-grid { grid-template-columns: repeat(3, 1fr); gap: 0.75rem; }
    .sk-card-overlay { opacity: 1; }
  }
  @media (max-width: 480px) {
    .sk-stats-grid { grid-template-columns: 1fr 1fr; }
    .sk-stat-featured { grid-column: span 2; }
    .sk-gallery-grid { grid-template-columns: 1fr; }
    .sk-lb-nav { display: none; }
    .sk-stat-num { font-size: 2rem; }
    .sk-stat-featured .sk-stat-num { font-size: 2.5rem; }
    .sk-container { padding: 0 1.25rem; }
    .sk-signature-value { font-size: 1.75rem; }
  }
</style>

<script define:vars={{ galleryData: galleryItems, contactEmail: CONTACT_EMAIL, stateData: stateVisits }}>
  document.addEventListener('DOMContentLoaded', () => {
    // Light/dark mode toggle — both hero and nav buttons
    const SK_MODE_KEY = 'shakshuka-color-mode';

    function toggleMode() {
      document.body.classList.toggle('sk-light');
      const isLight = document.body.classList.contains('sk-light');
      localStorage.setItem(SK_MODE_KEY, isLight ? 'light' : 'dark');
    }

    document.getElementById('sk-mode-toggle').addEventListener('click', toggleMode);
    document.getElementById('sk-perch-mode').addEventListener('click', toggleMode);

    // Nav — hidden until user scrolls past hero
    const nav = document.getElementById('sk-nav');
    const hero = document.getElementById('the-perch');
    window.addEventListener('scroll', () => {
      const pastHero = hero ? window.scrollY > hero.offsetHeight * 0.7 : window.scrollY > 50;
      nav.classList.toggle('visible', pastHero);
      nav.classList.toggle('scrolled', pastHero);
    }, { passive: true });

    // Mobile nav
    document.getElementById('sk-nav-toggle').addEventListener('click', () => {
      document.getElementById('sk-nav-links').classList.toggle('open');
    });
    document.querySelectorAll('.sk-nav-links a').forEach(a => {
      a.addEventListener('click', () => document.getElementById('sk-nav-links').classList.remove('open'));
    });

    // ===== THE PERCH: Lens Magnify & Replay =====
    var skWordmark = document.getElementById('sk-wordmark');

    if (skWordmark) {
      var skLetters = skWordmark.querySelectorAll('.sk-letter');
      var perchSettled = false;
      var perchSettleTimer = null;

      var LENS_RADIUS = 120;
      var MAX_SCALE = 1.35;

      function schedulePerchSettle() {
        if (perchSettleTimer) clearTimeout(perchSettleTimer);
        perchSettleTimer = setTimeout(function() {
          skWordmark.classList.add('settled');
          perchSettled = true;
        }, 3500);
      }
      schedulePerchSettle();

      var isTouchDevice = window.matchMedia('(pointer: coarse)').matches;

      // Visual lens circle overlay
      var lensBeam = document.createElement('div');
      lensBeam.classList.add('sk-lens-beam');
      var lensCircle = document.createElement('div');
      lensCircle.classList.add('sk-lens-circle');
      lensCircle.style.width = (LENS_RADIUS * 2) + 'px';
      lensCircle.style.height = (LENS_RADIUS * 2) + 'px';
      lensBeam.appendChild(lensCircle);
      if (!isTouchDevice) document.body.appendChild(lensBeam);

      var lensVisible = false;

      function resetLetterScales() {
        skLetters.forEach(function(l) {
          l.style.setProperty('--sk-lens-scale', '1');
        });
      }

      document.addEventListener('mousemove', function(e) {
        if (isTouchDevice || !perchSettled) return;
        var Px = e.clientX;
        var Py = e.clientY;

        // Position the visual lens circle
        lensCircle.style.left = (Px - LENS_RADIUS) + 'px';
        lensCircle.style.top = (Py - LENS_RADIUS) + 'px';

        // Check if lens overlaps the wordmark
        var wRect = skWordmark.getBoundingClientRect();
        var closestX = Math.max(wRect.left, Math.min(Px, wRect.right));
        var closestY = Math.max(wRect.top, Math.min(Py, wRect.bottom));
        var touching = Math.sqrt((Px - closestX) * (Px - closestX) + (Py - closestY) * (Py - closestY)) <= LENS_RADIUS;

        if (touching && !lensVisible) {
          lensBeam.classList.add('visible');
          lensVisible = true;
        } else if (!touching && lensVisible) {
          lensBeam.classList.remove('visible');
          lensVisible = false;
          resetLetterScales();
        }

        if (!touching) return;

        // Scale each letter based on distance from cursor
        skLetters.forEach(function(letter) {
          var rect = letter.getBoundingClientRect();
          var cx = rect.left + rect.width / 2;
          var cy = rect.top + rect.height / 2;
          var dist = Math.sqrt((Px - cx) * (Px - cx) + (Py - cy) * (Py - cy));

          if (dist < LENS_RADIUS) {
            // Smooth falloff: max scale at center, 1.0 at edge
            var t = 1 - (dist / LENS_RADIUS);
            var scale = 1 + t * t * (MAX_SCALE - 1); // quadratic ease for smooth falloff
            letter.style.setProperty('--sk-lens-scale', scale.toFixed(3));
          } else {
            letter.style.setProperty('--sk-lens-scale', '1');
          }
        });
      });

      document.addEventListener('mouseleave', function() {
        lensBeam.classList.remove('visible');
        lensVisible = false;
        resetLetterScales();
      });

      // Click-to-replay
      skWordmark.addEventListener('click', function() {
        skWordmark.classList.remove('settled');
        perchSettled = false;
        lensBeam.classList.remove('visible');
        lensVisible = false;
        resetLetterScales();

        skLetters.forEach(function(letter) {
          letter.style.animation = 'none';
          letter.style.opacity = '0';
        });
        void skWordmark.offsetHeight;
        skLetters.forEach(function(letter) {
          letter.style.animation = '';
          letter.style.opacity = '';
        });

        var tagline = document.getElementById('sk-perch-tagline');
        var perchNavEl = document.getElementById('sk-perch-nav');
        [tagline, perchNavEl].forEach(function(el) {
          if (!el) return;
          el.style.animation = 'none';
          el.style.opacity = '0';
          void el.offsetHeight;
          el.style.animation = '';
          el.style.opacity = '';
        });

        schedulePerchSettle();
      });
    }

    // Gallery filters
    const filterBtns = document.querySelectorAll('.sk-filter-btn');
    const cards = document.querySelectorAll('.sk-card');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const f = btn.dataset.filter;
        filterBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        cards.forEach(c => { c.style.display = (f === 'all' || c.dataset.category === f) ? '' : 'none'; });
      });
    });

    // Field Guide - single-card carousel (one card visible, no peeking)
    const dexInner = document.getElementById('dex-track-inner');
    const dexLeft = document.getElementById('dex-left');
    const dexRight = document.getElementById('dex-right');
    const dexCards = document.querySelectorAll('.sk-dex-card');
    const GAP = 20;
    let dexOffset = 0;

    function getCardW() {
      return window.innerWidth <= 480 ? 220 : 250;
    }

    function updateDex() {
      if (!dexInner) return;
      const maxOffset = Math.max(dexCards.length - 1, 0);
      dexOffset = Math.min(dexOffset, maxOffset);
      dexOffset = Math.max(dexOffset, 0);
      const shift = dexOffset * (getCardW() + GAP);
      dexInner.style.transform = 'translateX(-' + shift + 'px)';
      if (dexLeft) dexLeft.classList.toggle('disabled', dexOffset === 0);
      if (dexRight) dexRight.classList.toggle('disabled', dexOffset >= maxOffset);
    }

    dexLeft?.addEventListener('click', () => { dexOffset--; updateDex(); });
    dexRight?.addEventListener('click', () => { dexOffset++; updateDex(); });
    window.addEventListener('resize', () => updateDex());
    updateDex();

    document.querySelectorAll('.sk-dex-card').forEach(card => {
      card.addEventListener('click', () => card.classList.toggle('flipped'));
    });

    // Bird species database for autocomplete
    const knownBirds = [
      'American Robin','American Goldfinch','American Crow','American Kestrel','American Woodcock','American Bittern','American Coot','American White Pelican','American Wigeon','American Redstart',
      'Bald Eagle','Baltimore Oriole','Barn Owl','Barn Swallow','Barred Owl','Belted Kingfisher','Black-capped Chickadee','Blue Jay','Blue-winged Teal','Bobolink','Brown Thrasher','Brown Creeper','Brown-headed Cowbird','Broad-winged Hawk','Bufflehead',
      'Canada Goose','Carolina Wren','Cedar Waxwing','Chimney Swift','Chipping Sparrow','Clay-colored Sparrow','Common Loon','Common Grackle','Common Merganser','Common Nighthawk','Common Yellowthroat','Cooper\'s Hawk',
      'Dark-eyed Junco','Double-crested Cormorant','Downy Woodpecker','Dunlin',
      'Eastern Bluebird','Eastern Kingbird','Eastern Meadowlark','Eastern Phoebe','Eastern Screech-Owl','Eastern Towhee','Eastern Wood-Pewee','European Starling',
      'Fox Sparrow','Field Sparrow',
      'Golden-crowned Kinglet','Gray Catbird','Great Blue Heron','Great Horned Owl','Great Egret','Greater Yellowlegs','Green Heron','Green-winged Teal',
      'Hairy Woodpecker','Hermit Thrush','Herring Gull','Hooded Merganser','Hooded Warbler','House Finch','House Sparrow','House Wren',
      'Indigo Bunting',
      'Killdeer','King Rail',
      'Least Sandpiper','Least Flycatcher','Lesser Yellowlegs','Lincoln\'s Sparrow','Loggerhead Shrike','Long-eared Owl',
      'Magnolia Warbler','Mallard','Marsh Wren','Merlin','Mourning Dove','Mourning Warbler',
      'Nashville Warbler','Northern Cardinal','Northern Flicker','Northern Harrier','Northern Mockingbird','Northern Pintail','Northern Rough-winged Swallow','Northern Saw-whet Owl','Northern Shoveler',
      'Olive-sided Flycatcher','Orange-crowned Warbler','Orchard Oriole','Osprey','Ovenbird',
      'Palm Warbler','Peregrine Falcon','Philadelphia Vireo','Pied-billed Grebe','Pileated Woodpecker','Pine Siskin','Pine Warbler','Prothonotary Warbler','Purple Finch','Purple Martin',
      'Red-bellied Woodpecker','Red-breasted Nuthatch','Red-eyed Vireo','Red-headed Woodpecker','Red-shouldered Hawk','Red-tailed Hawk','Red-winged Blackbird','Ring-billed Gull','Ring-necked Duck','Ring-necked Pheasant','Rose-breasted Grosbeak','Ruby-crowned Kinglet','Ruby-throated Hummingbird','Ruddy Duck','Ruffed Grouse','Rusty Blackbird',
      'Sandhill Crane','Savannah Sparrow','Scarlet Tanager','Sedge Wren','Sharp-shinned Hawk','Short-eared Owl','Snowy Owl','Solitary Sandpiper','Song Sparrow','Spotted Sandpiper','Swainson\'s Thrush','Swamp Sparrow',
      'Tennessee Warbler','Tree Swallow','Trumpeter Swan','Tufted Titmouse','Turkey Vulture',
      'Veery','Virginia Rail',
      'Warbling Vireo','White-breasted Nuthatch','White-crowned Sparrow','White-throated Sparrow','Wild Turkey','Willow Flycatcher','Wilson\'s Warbler','Winter Wren','Wood Duck','Wood Thrush',
      'Yellow Warbler','Yellow-bellied Sapsucker','Yellow-billed Cuckoo','Yellow-rumped Warbler','Yellow-throated Vireo',
    ];
    const guideNames = Array.from(dexCards).map(c => c.querySelector('.sk-dex-name')?.textContent || '');
    const guideScientific = Array.from(document.querySelectorAll('#field-guide .sk-dex-scientific')).map(el => el.textContent || '');
    const spottedSet = new Set(guideNames.map(n => n.toLowerCase()));
    const allBirds = [...new Set([...guideNames, ...knownBirds])].sort();

    const dexSearch = document.getElementById('dex-search');
    const dexSuggestions = document.getElementById('dex-suggestions');
    let sugIdx = -1;

    function scoreBird(name, query) {
      const nl = name.toLowerCase();
      const ql = query.toLowerCase();
      if (nl === ql) return 100;
      if (nl.startsWith(ql)) return 80;
      const words = nl.split(/[\s-]+/);
      if (words.some(w => w.startsWith(ql))) return 60;
      if (nl.includes(ql)) return 40;
      return 0;
    }

    function renderSuggestions(query) {
      if (!query.trim()) { dexSuggestions.classList.remove('open'); dexSuggestions.innerHTML = ''; sugIdx = -1; return; }
      const scored = allBirds.map(b => ({ name: b, score: scoreBird(b, query) })).filter(b => b.score > 0).sort((a, b) => b.score - a.score).slice(0, 8);
      if (!scored.length) { dexSuggestions.classList.remove('open'); dexSuggestions.innerHTML = ''; sugIdx = -1; return; }
      sugIdx = -1;
      dexSuggestions.innerHTML = scored.map((b, i) => {
        const inGuide = spottedSet.has(b.name.toLowerCase());
        const gi = guideNames.findIndex(n => n.toLowerCase() === b.name.toLowerCase());
        const sci = gi >= 0 ? guideScientific[gi] : '';
        return '<div class="sk-dex-sug-item" data-idx="' + i + '" data-bird="' + b.name.replace(/"/g, '&quot;') + '">' +
          '<span><span class="sk-dex-sug-name">' + b.name + '</span>' + (sci ? ' <span class="sk-dex-sug-sci">' + sci + '</span>' : '') + '</span>' +
          '<span class="sk-dex-sug-tag ' + (inGuide ? 'spotted' : 'unspotted') + '">' + (inGuide ? 'In Guide' : 'Not Spotted') + '</span>' +
          '</div>';
      }).join('');
      dexSuggestions.classList.add('open');
      dexSuggestions.querySelectorAll('.sk-dex-sug-item').forEach(item => {
        item.addEventListener('click', () => selectBird(item.dataset.bird));
      });
    }

    function selectBird(name) {
      dexSearch.value = name;
      dexSuggestions.classList.remove('open');
      const idx = guideNames.findIndex(n => n.toLowerCase() === name.toLowerCase());
      if (idx >= 0) { dexOffset = idx; updateDex(); }
    }

    dexSearch?.addEventListener('input', (e) => renderSuggestions(e.target.value));
    dexSearch?.addEventListener('keydown', (e) => {
      const items = dexSuggestions.querySelectorAll('.sk-dex-sug-item');
      if (!items.length) return;
      if (e.key === 'ArrowDown') { e.preventDefault(); sugIdx = Math.min(sugIdx + 1, items.length - 1); items.forEach((it, i) => it.classList.toggle('active', i === sugIdx)); }
      else if (e.key === 'ArrowUp') { e.preventDefault(); sugIdx = Math.max(sugIdx - 1, 0); items.forEach((it, i) => it.classList.toggle('active', i === sugIdx)); }
      else if (e.key === 'Enter' && sugIdx >= 0) { e.preventDefault(); selectBird(items[sugIdx].dataset.bird); }
      else if (e.key === 'Escape') { dexSuggestions.classList.remove('open'); }
    });
    document.addEventListener('click', (e) => { if (!e.target.closest('.sk-dex-search-box')) dexSuggestions.classList.remove('open'); });

    // Lightbox
    const lb = document.getElementById('sk-lightbox');
    const lbImg = lb.querySelector('.sk-lb-img');
    const lbTitle = lb.querySelector('.sk-lb-title');
    const lbSpecies = lb.querySelector('.sk-lb-species');
    const lbMeta = lb.querySelector('.sk-lb-meta');
    const lbBuy = lb.querySelector('.sk-lb-buy');
    let currentIdx = 0;
    let filtered = galleryData;

    function showItem(idx) {
      const item = filtered[idx];
      if (!item) return;
      lbImg.src = item.src || item.thumb;
      lbImg.alt = item.title;
      lbTitle.textContent = item.title;
      lbSpecies.textContent = item.species || '';
      lbSpecies.style.display = item.species ? '' : 'none';
      const d = new Date(item.date + 'T00:00:00');
      lbMeta.textContent = item.location + ' \u2022 ' + d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
      if (item.forSale) {
        lbBuy.style.display = 'inline-block';
        const subj = encodeURIComponent('Purchase Inquiry: ' + item.title);
        const body = encodeURIComponent('Hi Shakshuka,\n\nI\'m interested in purchasing a print of "' + item.title + '".\n\nPlease let me know about available sizes and pricing.\n\nThank you!');
        lbBuy.href = 'mailto:' + contactEmail + '?subject=' + subj + '&body=' + body;
      } else {
        lbBuy.style.display = 'none';
      }
    }

    function openLB(id) {
      const activeF = document.querySelector('.sk-filter-btn.active')?.dataset.filter || 'all';
      filtered = activeF === 'all' ? galleryData : galleryData.filter(i => i.category === activeF);
      currentIdx = filtered.findIndex(i => i.id === id);
      if (currentIdx < 0) currentIdx = 0;
      showItem(currentIdx);
      lb.classList.add('open');
      document.body.style.overflow = 'hidden';
    }

    function closeLB() {
      lb.classList.remove('open');
      document.body.style.overflow = '';
    }

    cards.forEach(c => c.addEventListener('click', () => openLB(Number(c.dataset.id))));
    lb.querySelector('.sk-lb-close').addEventListener('click', closeLB);
    lb.querySelector('.sk-lb-prev').addEventListener('click', () => { currentIdx = (currentIdx - 1 + filtered.length) % filtered.length; showItem(currentIdx); });
    lb.querySelector('.sk-lb-next').addEventListener('click', () => { currentIdx = (currentIdx + 1) % filtered.length; showItem(currentIdx); });
    lb.addEventListener('click', e => { if (e.target === lb) closeLB(); });
    document.addEventListener('keydown', e => {
      if (!lb.classList.contains('open')) return;
      if (e.key === 'Escape') closeLB();
      if (e.key === 'ArrowLeft') { currentIdx = (currentIdx - 1 + filtered.length) % filtered.length; showItem(currentIdx); }
      if (e.key === 'ArrowRight') { currentIdx = (currentIdx + 1) % filtered.length; showItem(currentIdx); }
    });

    // Stat count-up
    function animateCount(el, target) {
      const duration = 2000;
      const start = performance.now();
      function tick(now) {
        const p = Math.min((now - start) / duration, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        el.textContent = Math.round(target * eased).toLocaleString();
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    // Scroll animations
    const observer = new IntersectionObserver(entries => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          if (entry.target.classList.contains('sk-stat-num')) {
            animateCount(entry.target, parseInt(entry.target.dataset.target));
          }
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.15 });

    document.querySelectorAll('.sk-anim, .sk-stat-num').forEach(el => observer.observe(el));

    // ========== SVG HEATMAP ==========
    let activeMetric = 'visits';
    const svgContainer = document.getElementById('sk-svg-container');
    const tip = document.getElementById('sk-tooltip');
    const tipName = tip.querySelector('.sk-tooltip-name');
    const tipMetrics = tip.querySelector('.sk-tooltip-metrics');
    const tipSpecies = tip.querySelector('.sk-tooltip-species');
    const detailPanel = document.getElementById('sk-state-detail');
    const legendMin = document.querySelector('.sk-legend-min');
    const legendMax = document.querySelector('.sk-legend-max');

    // Fetch and inject SVG
    async function loadMap() {
      try {
        const res = await fetch('/images/shakshuka/us-states.svg');
        const svgText = await res.text();
        svgContainer.innerHTML = '<div class="sk-svg-wrap">' + svgText + '</div>';
        svgContainer.querySelectorAll('title').forEach(t => t.remove());
        svgContainer.querySelectorAll('.dccircle').forEach(el => el.remove());
        colorMap(activeMetric);
        attachMapListeners();
      } catch (e) {
        svgContainer.innerHTML = '<p style="text-align:center;color:#555;padding:3rem 0">Map could not be loaded.</p>';
      }
    }

    function getMetricValue(code, metric) {
      const d = stateData[code];
      if (!d) return 0;
      return d[metric] || 0;
    }

    function colorMap(metric) {
      const paths = svgContainer.querySelectorAll('[data-state]');
      const maxVal = Math.max(...Object.values(stateData).map(d => d[metric] || 0), 1);
      legendMin.textContent = '0';
      legendMax.textContent = maxVal.toLocaleString();

      paths.forEach(path => {
        const code = path.getAttribute('data-state');
        const val = getMetricValue(code, metric);
        if (val > 0) {
          const intensity = val / maxVal;
          const opacity = Math.max(intensity * 0.85, 0.12);
          path.style.fill = 'rgba(91, 140, 62, ' + opacity + ')';
        } else {
          path.style.fill = 'rgba(255, 255, 255, 0.04)';
        }
        path.style.stroke = getComputedStyle(document.body).getPropertyValue('--sk-map-stroke').trim() || '#1a1f1c';
        path.style.strokeWidth = '0.5';
      });
    }

    function attachMapListeners() {
      const paths = svgContainer.querySelectorAll('[data-state]');
      paths.forEach(path => {
        const code = path.getAttribute('data-state');
        const titleEl = path.querySelector('title');
        const name = titleEl ? titleEl.textContent : code;

        path.addEventListener('mouseenter', () => {
          const d = stateData[code];
          tipName.textContent = name;
          if (d) {
            tipMetrics.textContent = d.visits + ' visits \u00B7 ' + d.species + ' species \u00B7 ' + d.photos.toLocaleString() + ' photos';
            tipSpecies.textContent = 'Top: ' + d.topSpecies;
          } else {
            tipMetrics.textContent = 'Not yet visited';
            tipSpecies.textContent = '';
          }
          tip.classList.add('visible');

          const svg = svgContainer.querySelector('svg');
          if (!svg) return;

          // Calculate directional lift away from map center
          const bbox = path.getBBox();
          const cx = bbox.x + bbox.width / 2;
          const cy = bbox.y + bbox.height / 2;
          const mapCx = 959 / 2;
          const mapCy = 593 / 2;
          let dx = cx - mapCx;
          let dy = cy - mapCy;
          const dist = Math.sqrt(dx * dx + dy * dy) || 1;
          const liftDist = 10;
          dx = (dx / dist) * liftDist;
          dy = (dy / dist) * liftDist;

          // Convert SVG units to CSS pixels
          const svgRect = svg.getBoundingClientRect();
          const pxPerUnit = svgRect.width / 959;
          const cssDx = dx * pxPerUnit;
          const cssDy = dy * pxPerUnit;

          path.style.transform = 'translate(' + cssDx + 'px, ' + cssDy + 'px) scale(1.03)';
          path.style.filter = 'brightness(1.4) drop-shadow(0 0 8px rgba(91, 140, 62, 0.6))';
          path.style.stroke = '#5B8C3E';
          path.style.strokeWidth = '1.5';
        });

        path.addEventListener('mousemove', e => {
          let x = e.clientX + 16;
          let y = e.clientY + 16;
          if (x + tip.offsetWidth > window.innerWidth - 8)
            x = e.clientX - tip.offsetWidth - 16;
          if (y + tip.offsetHeight > window.innerHeight - 8)
            y = e.clientY - tip.offsetHeight - 16;
          tip.style.left = x + 'px';
          tip.style.top = y + 'px';
        });

        path.addEventListener('mouseleave', () => {
          tip.classList.remove('visible');
          path.style.transform = '';
          path.style.filter = '';
          path.style.stroke = getComputedStyle(document.body).getPropertyValue('--sk-map-stroke').trim() || '#1a1f1c';
          path.style.strokeWidth = '0.5';
        });

        path.addEventListener('click', () => {
          const d = stateData[code];
          if (!d) return;
          detailPanel.style.display = 'block';
          detailPanel.querySelector('.sk-detail-name').textContent = d.name;
          document.getElementById('sd-visits').textContent = d.visits;
          document.getElementById('sd-species').textContent = d.species;
          document.getElementById('sd-photos').textContent = d.photos.toLocaleString();
          detailPanel.querySelector('.sk-detail-top-name').textContent = d.topSpecies;
          detailPanel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        });
      });
    }

    // Detail close
    document.getElementById('sk-detail-close').addEventListener('click', () => {
      detailPanel.style.display = 'none';
    });

    // Metric toggle chips
    document.querySelectorAll('.sk-chip').forEach(chip => {
      chip.addEventListener('click', () => {
        document.querySelectorAll('.sk-chip').forEach(c => c.classList.remove('active'));
        chip.classList.add('active');
        activeMetric = chip.dataset.metric;
        colorMap(activeMetric);
      });
    });

    loadMap();
  });
</script>
