    --sk-green-bg-strong: rgba(91,140,62,0.15);
    --sk-gold: #C4813D;
    --sk-gold-hover: #a86d32;
    --sk-gold-bg: rgba(196,129,61,0.18);
    --sk-gold-border: rgba(196,129,61,0.25);
    --sk-border: #2a302c;
    --sk-border-sug: #222;
    --sk-nav-scrolled: rgba(15,18,16,0.95);
    --sk-nav-shadow: 0 1px 0 rgba(255,255,255,0.05);
    --sk-hero-overlay: linear-gradient(to bottom, rgba(15,18,16,0.82) 0%, rgba(15,18,16,0.88) 50%, rgba(15,18,16,0.98) 100%);
    --sk-card-overlay: linear-gradient(to top, rgba(0,0,0,0.85), transparent);
    --sk-glass: rgba(255,255,255,0.15);
    --sk-glass-strong: rgba(255,255,255,0.2);
    --sk-glass-faint: rgba(255,255,255,0.04);
