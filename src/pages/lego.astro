---
// /lego — standalone play page using the same gate component as `/`.
// On solve the brick drops out and the page fades to dark; refresh to play
// again. (No redirect — `/` has its own gate.)
import LegoGate from '../components/LegoGate.astro';
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
  <meta name="theme-color" content="#0a0a0a" />
  <title>:: lego play ::</title>
  <style>
    html, body { margin: 0; padding: 0; height: 100%; background: #0a0a0a; }
  </style>
</head>
<body>
  <LegoGate hints={false} />
</body>
</html>
