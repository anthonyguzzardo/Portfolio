---
const fieldGuide = [
  { id: 1, name: 'Red-tailed Hawk', scientific: 'Buteo jamaicensis', img: 'https://picsum.photos/seed/rthawk/400/500', habitat: 'Open fields, forests', diet: 'Small mammals, birds', wingspan: '45-52 in', weight: '1.5-3.5 lb', status: 'Least Concern', firstSeen: '2024-03-12', location: 'Starved Rock, IL', sightings: 23, rarity: 'common' },
  { id: 2, name: 'Great Blue Heron', scientific: 'Ardea herodias', img: 'https://picsum.photos/seed/gbheron/400/500', habitat: 'Wetlands, shorelines', diet: 'Fish, amphibians', wingspan: '66-79 in', weight: '4.6-5.5 lb', status: 'Least Concern', firstSeen: '2024-04-08', location: "Chain O' Lakes, IL", sightings: 18, rarity: 'common' },
  { id: 3, name: 'Bald Eagle', scientific: 'Haliaeetus leucocephalus', img: 'https://picsum.photos/seed/baldeagle/400/500', habitat: 'Near large bodies of water', diet: 'Fish, waterfowl', wingspan: '71-91 in', weight: '6.6-14 lb', status: 'Least Concern', firstSeen: '2024-06-20', location: 'Mississippi River Valley, IA', sightings: 8, rarity: 'uncommon' },
  { id: 4, name: 'Great Horned Owl', scientific: 'Bubo virginianus', img: 'https://picsum.photos/seed/ghowl/400/500', habitat: 'Forests, swamps, deserts', diet: 'Mammals, birds, reptiles', wingspan: '40-57 in', weight: '2-5.5 lb', status: 'Least Concern', firstSeen: '2025-01-12', location: 'Morton Arboretum, IL', sightings: 5, rarity: 'uncommon' },
  { id: 5, name: 'Belted Kingfisher', scientific: 'Megaceryle alcyon', img: 'https://picsum.photos/seed/bkingfish/400/500', habitat: 'Streams, rivers, ponds', diet: 'Fish, crayfish', wingspan: '19-23 in', weight: '5-6 oz', status: 'Least Concern', firstSeen: '2025-07-04', location: 'Galena, IL', sightings: 3, rarity: 'uncommon' },
  { id: 6, name: 'Yellow Warbler', scientific: 'Setophaga petechia', img: 'https://picsum.photos/seed/ywarbler/400/500', habitat: 'Thickets, wetlands', diet: 'Insects, berries', wingspan: '6.3-7.9 in', weight: '0.3-0.4 oz', status: 'Least Concern', firstSeen: '2025-05-10', location: 'Magee Marsh, OH', sightings: 12, rarity: 'common' },
  { id: 7, name: 'Sandhill Crane', scientific: 'Antigone canadensis', img: 'https://picsum.photos/seed/shcrane/400/500', habitat: 'Marshes, grasslands', diet: 'Seeds, grains, insects', wingspan: '73-90 in', weight: '7.3-11 lb', status: 'Least Concern', firstSeen: '2025-11-01', location: 'Jasper-Pulaski FWA, IN', sightings: 15, rarity: 'common' },
  { id: 8, name: 'Snowy Owl', scientific: 'Bubo scandiacus', img: 'https://picsum.photos/seed/snowyowl/400/500', habitat: 'Open tundra, fields', diet: 'Lemmings, small mammals', wingspan: '49-59 in', weight: '3.5-6.5 lb', status: 'Vulnerable', firstSeen: '2026-03-20', location: 'Illinois Beach SP, IL', sightings: 1, rarity: 'rare' },
  { id: 9, name: 'Pileated Woodpecker', scientific: 'Dryocopus pileatus', img: 'https://picsum.photos/seed/pwood/400/500', habitat: 'Mature forests', diet: 'Carpenter ants, beetles', wingspan: '26-30 in', weight: '8.8-12.3 oz', status: 'Least Concern', firstSeen: '2026-03-28', location: 'Starved Rock, IL', sightings: 4, rarity: 'uncommon' },
  { id: 10, name: 'American Kestrel', scientific: 'Falco sparverius', img: 'https://picsum.photos/seed/akestrel/400/500', habitat: 'Open country, cities', diet: 'Insects, small birds', wingspan: '20-24 in', weight: '2.8-5.8 oz', status: 'Least Concern', firstSeen: '2026-03-25', location: 'Midewin Prairie, IL', sightings: 6, rarity: 'common' },
  { id: 11, name: 'Northern Cardinal', scientific: 'Cardinalis cardinalis', img: 'https://picsum.photos/seed/ncard/400/500', habitat: 'Woodlands, gardens', diet: 'Seeds, fruits, insects', wingspan: '10-12 in', weight: '1.5-1.7 oz', status: 'Least Concern', firstSeen: '2024-02-14', location: 'Morton Arboretum, IL', sightings: 47, rarity: 'common' },
  { id: 12, name: "Cooper's Hawk", scientific: 'Accipiter cooperii', img: 'https://picsum.photos/seed/coophawk/400/500', habitat: 'Forests, wooded suburbs', diet: 'Medium-sized birds', wingspan: '24-36 in', weight: '7.8-24 oz', status: 'Least Concern', firstSeen: '2026-03-15', location: 'Waterfall Glen, IL', sightings: 7, rarity: 'uncommon' },
  { id: 13, name: 'Common Loon', scientific: 'Gavia immer', img: 'https://picsum.photos/seed/cloon/400/500', habitat: 'Lakes, coastal waters', diet: 'Fish', wingspan: '41-52 in', weight: '6.5-12 lb', status: 'Least Concern', firstSeen: '2025-08-15', location: 'Traverse City, MI', sightings: 3, rarity: 'uncommon' },
  { id: 14, name: 'Eastern Bluebird', scientific: 'Sialia sialis', img: 'https://picsum.photos/seed/eblue/400/500', habitat: 'Open woodlands, farmland', diet: 'Insects, berries', wingspan: '9.8-12.6 in', weight: '0.95-1.2 oz', status: 'Least Concern', firstSeen: '2025-04-22', location: 'Brown County SP, IN', sightings: 9, rarity: 'common' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Field Guide | Shakshuka</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
</head>
<body>
<script is:inline>
  if (localStorage.getItem('shakshuka-color-mode') === 'light') {
    document.body.classList.add('sk-light');
  }
</script>

  <nav class="fg-nav">
    <a href="/shakshuka" class="fg-back">
      <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
      Back to Shakshuka
    </a>
    <button class="fg-mode-toggle" id="fg-mode-toggle" aria-label="Toggle light/dark mode">
      <svg class="fg-icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
      </svg>
      <svg class="fg-icon-moon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
      </svg>
    </button>
  </nav>

  <main class="fg-main">
    <h1 class="fg-title">Field Guide</h1>
    <p class="fg-sub">{fieldGuide.length} species catalogued</p>

    <div class="fg-search-wrap">
      <div class="fg-search-box">
        <svg class="fg-search-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input type="text" class="fg-search" id="fg-search" placeholder="Search species..." autocomplete="off" />
        <div class="fg-suggestions" id="fg-suggestions"></div>
      </div>
      <p class="fg-search-count" id="fg-search-count"></p>
    </div>

    <div class="fg-grid">
      {fieldGuide.map((bird) => (
        <div class="sk-dex-card" data-rarity={bird.rarity} data-name={bird.name.toLowerCase()} data-scientific={bird.scientific.toLowerCase()} data-habitat={bird.habitat.toLowerCase()} data-location={bird.location.toLowerCase()}>
          <div class="sk-dex-card-inner">
            <div class="sk-dex-front">
              <div class="sk-dex-header">
                <div class="sk-dex-number">Lifer #{String(bird.id).padStart(3, '0')} <span class="sk-dex-of">/ {fieldGuide.length}</span></div>
                <div class="sk-dex-rarity">{bird.rarity}</div>
              </div>
              <div class="sk-dex-img-wrap">
                <img src={bird.img} alt={bird.name} loading="lazy" />
              </div>
              <h3 class="sk-dex-name">{bird.name}</h3>
              <p class="sk-dex-scientific">{bird.scientific}</p>
              <div class="sk-dex-quick">
                <span>{bird.habitat.split(',')[0]}</span>
                <span>{bird.location.split(',')[0]}</span>
                <span>{bird.sightings}x seen</span>
              </div>
              <div class="sk-dex-flip-hint">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
              </div>
            </div>
            <div class="sk-dex-back">
              <div class="sk-dex-number">Lifer #{String(bird.id).padStart(3, '0')}</div>
              <h3 class="sk-dex-name">{bird.name}</h3>
              <div class="sk-dex-details">
                <div class="sk-dex-row"><span class="sk-dex-label">Habitat</span><span>{bird.habitat}</span></div>
                <div class="sk-dex-row"><span class="sk-dex-label">Diet</span><span>{bird.diet}</span></div>
                <div class="sk-dex-row"><span class="sk-dex-label">Wingspan</span><span>{bird.wingspan}</span></div>
                <div class="sk-dex-row"><span class="sk-dex-label">Weight</span><span>{bird.weight}</span></div>
                <div class="sk-dex-row"><span class="sk-dex-label">Status</span><span class={bird.status === 'Vulnerable' ? 'sk-dex-warn' : ''}>{bird.status}</span></div>
                <div class="sk-dex-row"><span class="sk-dex-label">First Seen</span><span>{new Date(bird.firstSeen + 'T00:00:00').toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span></div>
                <div class="sk-dex-row"><span class="sk-dex-label">Location</span><span>{bird.location}</span></div>
                <div class="sk-dex-row"><span class="sk-dex-label">Sightings</span><span>{bird.sightings}</span></div>
              </div>
              <div class="sk-dex-flip-hint">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M17 1l4 4-4 4"/><path d="M3 11V9a4 4 0 0 1 4-4h14"/><path d="M7 23l-4-4 4-4"/><path d="M21 13v2a4 4 0 0 1-4 4H3"/></svg>
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </main>

</body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body {
    --sk-bg: #0f1210;
    --sk-bg-surface: #1a1f1c;
    --sk-text: #e8e4dc;
    --sk-text-muted: #8a8474;
    --sk-text-faint: #555;
    --sk-text-faintest: #444;
    --sk-text-sub: #a09882;
    --sk-green: #7DB356;
    --sk-green-dark: #5B8C3E;
    --sk-green-bg: rgba(91,140,62,0.12);
    --sk-green-bg-strong: rgba(91,140,62,0.15);
    --sk-gold: #C4813D;
    --sk-gold-bg: rgba(196,129,61,0.18);
    --sk-border: #2a302c;
    --sk-border-sug: #222;
    --sk-glass-faint: rgba(255,255,255,0.05);
    --sk-card-common-grad: linear-gradient(160deg, #1a1f1c 0%, #141914 100%);
    --sk-card-common-border: #3d5c2e;
    --sk-card-uncommon-grad: linear-gradient(160deg, #1c211a 0%, #161b14 100%);
    --sk-card-rare-grad: linear-gradient(160deg, #211d18 0%, #1a1610 100%);

    font-family: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    background: var(--sk-bg); color: var(--sk-text); line-height: 1.6;
    -webkit-font-smoothing: antialiased;
    transition: background 0.4s ease, color 0.4s ease;
  }

  body.sk-light {
    --sk-bg: #f7f5f0;
    --sk-bg-surface: #ffffff;
    --sk-text: #1a1510;
    --sk-text-muted: #5a5248;
    --sk-text-faint: #999;
    --sk-text-faintest: #aaa;
    --sk-text-sub: #4a4235;
    --sk-green: #4a7a35;
    --sk-green-dark: #3d6a2c;
    --sk-green-bg: rgba(74,122,53,0.1);
    --sk-green-bg-strong: rgba(74,122,53,0.12);
    --sk-gold: #b8742e;
    --sk-gold-bg: rgba(184,116,46,0.12);
    --sk-border: #ddd8d0;
    --sk-border-sug: #e5e0d8;
    --sk-glass-faint: rgba(0,0,0,0.03);
    --sk-card-common-grad: linear-gradient(160deg, #ffffff 0%, #f8f6f2 100%);
    --sk-card-common-border: #8cb875;
    --sk-card-uncommon-grad: linear-gradient(160deg, #fafaf7 0%, #f5f2ed 100%);
    --sk-card-rare-grad: linear-gradient(160deg, #fdf8f2 0%, #f8f0e4 100%);
  }
  img { max-width: 100%; display: block; }
  a { color: inherit; text-decoration: none; }
  h1, h3 { font-family: 'Playfair Display', Georgia, serif; font-weight: 600; line-height: 1.2; }

  .fg-nav {
    padding: 1.25rem 2rem; border-bottom: 1px solid var(--sk-border);
    display: flex; align-items: center; justify-content: space-between;
  }
  .fg-back {
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.85rem; color: var(--sk-text-muted); transition: color 0.2s;
  }
  .fg-back:hover { color: var(--sk-green); }

  .fg-mode-toggle {
    display: flex; align-items: center; justify-content: center;
    width: 36px; height: 36px; border-radius: 50%;
    border: 1px solid var(--sk-border); background: transparent;
    color: var(--sk-text-muted); cursor: pointer;
    transition: color 0.2s, border-color 0.2s, background 0.2s;
  }
  .fg-mode-toggle:hover { color: var(--sk-green); border-color: var(--sk-green-dark); background: var(--sk-green-bg); }
  .fg-mode-toggle svg { width: 18px; height: 18px; }
  .fg-mode-toggle .fg-icon-moon { display: none; }
  body.sk-light .fg-mode-toggle .fg-icon-sun { display: none; }
  body.sk-light .fg-mode-toggle .fg-icon-moon { display: block; }

  .fg-main {
    max-width: 1200px; margin: 0 auto; padding: 1.5rem 2rem 4rem;
  }
  .fg-title {
    font-size: 2.5rem; text-align: center; margin-bottom: 0.25rem;
  }
  .fg-sub {
    text-align: center; color: var(--sk-text-muted); font-size: 1rem; margin-bottom: 1rem;
  }
  .fg-search-wrap { display: flex; flex-direction: column; align-items: center; margin-bottom: 1rem; }
  .fg-search-box { position: relative; width: 100%; max-width: 400px; }
  .fg-search-icon {
    position: absolute; left: 12px; top: 50%; transform: translateY(-50%);
    color: var(--sk-green-dark); pointer-events: none;
  }
  .fg-search {
    width: 100%; padding: 0.65rem 0.75rem 0.65rem 2.25rem;
    background: var(--sk-bg-surface); border: 1px solid var(--sk-border); border-radius: 8px;
    color: var(--sk-text); font-family: 'Inter', sans-serif; font-size: 0.9rem;
    outline: none; transition: border-color 0.2s;
  }
  .fg-search::placeholder { color: var(--sk-text-faint); }
  .fg-search:focus { border-color: var(--sk-green-dark); }
  .fg-search-count { font-size: 0.75rem; color: var(--sk-text-faint); margin-top: 0.5rem; min-height: 1.1em; }
  .fg-suggestions {
    display: none; position: absolute; top: calc(100% + 4px); left: 0; right: 0;
    background: var(--sk-bg-surface); border: 1px solid var(--sk-border); border-radius: 8px;
    max-height: 240px; overflow-y: auto; z-index: 50;
  }
  .fg-suggestions.open { display: block; }
  .fg-sug-item {
    padding: 0.5rem 0.75rem; font-size: 0.8rem; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    transition: background 0.15s;
  }
  .fg-sug-item:hover, .fg-sug-item.active { background: var(--sk-green-bg); }
  .fg-sug-item + .fg-sug-item { border-top: 1px solid var(--sk-border-sug); }
  .fg-sug-name { color: var(--sk-text); }
  .fg-sug-sci { color: var(--sk-green); font-style: italic; font-size: 0.7rem; }
  .fg-sug-tag {
    font-size: 0.6rem; text-transform: uppercase; letter-spacing: 0.5px;
    padding: 0.1rem 0.4rem; border-radius: 100px; flex-shrink: 0; margin-left: 0.5rem;
  }
  .fg-sug-tag.spotted { color: var(--sk-green-dark); background: var(--sk-green-bg-strong); }
  .fg-sug-tag.unspotted { color: var(--sk-text-faint); background: var(--sk-glass-faint); }

  .sk-dex-card.hidden { display: none; }

  .fg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(250px, 1fr));
    gap: 1.25rem;
    justify-items: center;
  }

  /* Card styles (shared with main page) */
  .sk-dex-card {
    width: 250px; height: 420px;
    perspective: 900px; cursor: pointer;
  }
  .sk-dex-card-inner {
    width: 100%; height: 100%; position: relative;
    transition: transform 0.6s ease; transform-style: preserve-3d;
  }
  .sk-dex-card.flipped .sk-dex-card-inner { transform: rotateY(180deg); }
  .sk-dex-front, .sk-dex-back {
    position: absolute; inset: 0; backface-visibility: hidden; -webkit-backface-visibility: hidden;
    border-radius: 14px; padding: 1.25rem; display: flex; flex-direction: column;
    border: 2px solid var(--sk-border); overflow: hidden;
  }
  .sk-dex-back { transform: rotateY(180deg); }

  .sk-dex-card[data-rarity="common"] .sk-dex-front,
  .sk-dex-card[data-rarity="common"] .sk-dex-back {
    background: var(--sk-card-common-grad); border-color: var(--sk-card-common-border);
  }
  .sk-dex-card[data-rarity="uncommon"] .sk-dex-front,
  .sk-dex-card[data-rarity="uncommon"] .sk-dex-back {
    background: var(--sk-card-uncommon-grad); border-color: var(--sk-green-dark);
    box-shadow: 0 0 25px var(--sk-green-bg), inset 0 1px 0 rgba(91,140,62,0.08);
  }
  .sk-dex-card[data-rarity="rare"] .sk-dex-front,
  .sk-dex-card[data-rarity="rare"] .sk-dex-back {
    background: var(--sk-card-rare-grad); border-color: var(--sk-gold);
    box-shadow: 0 0 30px var(--sk-gold-bg), inset 0 1px 0 rgba(196,129,61,0.1);
  }

  .sk-dex-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.25rem; }
  .sk-dex-number { font-family: 'Inter', monospace; font-size: 0.7rem; font-weight: 600; color: var(--sk-green-dark); letter-spacing: 0.5px; }
  .sk-dex-of { color: var(--sk-text-faint); font-weight: 400; }
  .sk-dex-rarity { font-size: 0.6rem; font-weight: 600; text-transform: uppercase; letter-spacing: 1.5px; padding: 0.15rem 0.55rem; border-radius: 100px; }
  [data-rarity="common"] .sk-dex-rarity { color: var(--sk-green-dark); background: var(--sk-green-bg); }
  [data-rarity="uncommon"] .sk-dex-rarity { color: var(--sk-green); background: var(--sk-green-bg-strong); }
  [data-rarity="rare"] .sk-dex-rarity { color: var(--sk-gold); background: var(--sk-gold-bg); }

  .sk-dex-img-wrap { flex: 1; margin: 0.5rem 0; border-radius: 8px; overflow: hidden; background: var(--sk-bg); min-height: 0; }
  .sk-dex-img-wrap img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.4s ease; }
  .sk-dex-card-inner:hover .sk-dex-img-wrap img { transform: scale(1.05); }

  .sk-dex-name { font-family: 'Playfair Display', serif; font-size: 1.25rem; font-weight: 700; margin-bottom: 0.1rem; }
  .sk-dex-scientific { font-size: 0.75rem; color: var(--sk-green); font-style: italic; margin-bottom: 0.4rem; }
  .sk-dex-quick { display: flex; justify-content: space-between; font-size: 0.7rem; color: var(--sk-text-sub); letter-spacing: 0.2px; }
  .sk-dex-flip-hint { text-align: center; margin-top: auto; padding-top: 0.4rem; color: var(--sk-text-faintest); transition: color 0.2s; }
  .sk-dex-card-inner:hover .sk-dex-flip-hint { color: var(--sk-green); }

  .sk-dex-back .sk-dex-number { margin-bottom: 0.15rem; }
  .sk-dex-back .sk-dex-name { margin-bottom: 0.75rem; }
  .sk-dex-details { flex: 1; display: flex; flex-direction: column; gap: 0.45rem; }
  .sk-dex-row { display: flex; justify-content: space-between; align-items: baseline; font-size: 0.78rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--sk-border); }
  .sk-dex-row:last-child { border-bottom: none; }
  .sk-dex-label { color: var(--sk-text-muted); font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.5px; }
  .sk-dex-warn { color: var(--sk-gold); font-weight: 600; }

  @media (max-width: 480px) {
    .fg-title { font-size: 2rem; }
    .fg-grid { grid-template-columns: 1fr; }
    .sk-dex-card { width: 100%; max-width: 300px; }
  }
</style>

<script>
  // Light/dark toggle — shares key with shakshuka page
  document.getElementById('fg-mode-toggle')?.addEventListener('click', () => {
    document.body.classList.toggle('sk-light');
    const isLight = document.body.classList.contains('sk-light');
    localStorage.setItem('shakshuka-color-mode', isLight ? 'light' : 'dark');
  });

  document.querySelectorAll('.sk-dex-card').forEach(card => {
    card.addEventListener('click', () => card.classList.toggle('flipped'));
  });

  const knownBirds = [
    'American Robin','American Goldfinch','American Crow','American Kestrel','American Woodcock','American Bittern','American Coot','American White Pelican','American Wigeon','American Redstart',
    'Bald Eagle','Baltimore Oriole','Barn Owl','Barn Swallow','Barred Owl','Belted Kingfisher','Black-capped Chickadee','Blue Jay','Blue-winged Teal','Bobolink','Brown Thrasher','Brown Creeper','Brown-headed Cowbird','Broad-winged Hawk','Bufflehead',
    'Canada Goose','Carolina Wren','Cedar Waxwing','Chimney Swift','Chipping Sparrow','Clay-colored Sparrow','Common Loon','Common Grackle','Common Merganser','Common Nighthawk','Common Yellowthroat','Cooper\'s Hawk',
    'Dark-eyed Junco','Double-crested Cormorant','Downy Woodpecker','Dunlin',
    'Eastern Bluebird','Eastern Kingbird','Eastern Meadowlark','Eastern Phoebe','Eastern Screech-Owl','Eastern Towhee','Eastern Wood-Pewee','European Starling',
    'Fox Sparrow','Field Sparrow',
    'Golden-crowned Kinglet','Gray Catbird','Great Blue Heron','Great Horned Owl','Great Egret','Greater Yellowlegs','Green Heron','Green-winged Teal',
    'Hairy Woodpecker','Hermit Thrush','Herring Gull','Hooded Merganser','Hooded Warbler','House Finch','House Sparrow','House Wren',
    'Indigo Bunting',
    'Killdeer','King Rail',
    'Least Sandpiper','Least Flycatcher','Lesser Yellowlegs','Lincoln\'s Sparrow','Loggerhead Shrike','Long-eared Owl',
    'Magnolia Warbler','Mallard','Marsh Wren','Merlin','Mourning Dove','Mourning Warbler',
    'Nashville Warbler','Northern Cardinal','Northern Flicker','Northern Harrier','Northern Mockingbird','Northern Pintail','Northern Rough-winged Swallow','Northern Saw-whet Owl','Northern Shoveler',
    'Olive-sided Flycatcher','Orange-crowned Warbler','Orchard Oriole','Osprey','Ovenbird',
    'Palm Warbler','Peregrine Falcon','Philadelphia Vireo','Pied-billed Grebe','Pileated Woodpecker','Pine Siskin','Pine Warbler','Prothonotary Warbler','Purple Finch','Purple Martin',
    'Red-bellied Woodpecker','Red-breasted Nuthatch','Red-eyed Vireo','Red-headed Woodpecker','Red-shouldered Hawk','Red-tailed Hawk','Red-winged Blackbird','Ring-billed Gull','Ring-necked Duck','Ring-necked Pheasant','Rose-breasted Grosbeak','Ruby-crowned Kinglet','Ruby-throated Hummingbird','Ruddy Duck','Ruffed Grouse','Rusty Blackbird',
    'Sandhill Crane','Savannah Sparrow','Scarlet Tanager','Sedge Wren','Sharp-shinned Hawk','Short-eared Owl','Snowy Owl','Solitary Sandpiper','Song Sparrow','Spotted Sandpiper','Swainson\'s Thrush','Swamp Sparrow',
    'Tennessee Warbler','Tree Swallow','Trumpeter Swan','Tufted Titmouse','Turkey Vulture',
    'Veery','Virginia Rail',
    'Warbling Vireo','White-breasted Nuthatch','White-crowned Sparrow','White-throated Sparrow','Wild Turkey','Willow Flycatcher','Wilson\'s Warbler','Winter Wren','Wood Duck','Wood Thrush',
    'Yellow Warbler','Yellow-bellied Sapsucker','Yellow-billed Cuckoo','Yellow-rumped Warbler','Yellow-throated Vireo',
  ];

  const fgCards = document.querySelectorAll('.fg-grid .sk-dex-card');
  const fgSearch = document.getElementById('fg-search');
  const fgSuggestions = document.getElementById('fg-suggestions');
  const fgCount = document.getElementById('fg-search-count');
  const grid = document.querySelector('.fg-grid');
  const guideNames = Array.from(fgCards).map(c => c.dataset.name || '');
  const guideSci = Array.from(fgCards).map(c => c.dataset.scientific || '');
  const spottedSet = new Set(guideNames);
  const allBirds = [...new Set([...Array.from(fgCards).map(c => (c.querySelector('.sk-dex-name')?.textContent || '')), ...knownBirds])].sort();
  let sugIdx = -1;

  function scoreBird(name, query) {
    const nl = name.toLowerCase(), ql = query.toLowerCase();
    if (nl === ql) return 100;
    if (nl.startsWith(ql)) return 80;
    if (nl.split(/[\s-]+/).some(w => w.startsWith(ql))) return 60;
    if (nl.includes(ql)) return 40;
    return 0;
  }

  function scoreCard(card, query) {
    const ql = query.toLowerCase();
    const fields = ['name', 'scientific', 'habitat', 'location'];
    let best = 0;
    for (const f of fields) {
      const val = card.dataset[f] || '';
      if (val === ql) best = Math.max(best, 100);
      else if (val.startsWith(ql)) best = Math.max(best, 80);
      else if (val.split(/[\s,-]+/).some(w => w.startsWith(ql))) best = Math.max(best, 60);
      else if (val.includes(ql)) best = Math.max(best, 40);
    }
    return best;
  }

  function filterGrid(query) {
    if (!query.trim()) {
      fgCards.forEach(c => { c.classList.remove('hidden'); c.style.order = ''; });
      fgCount.textContent = '';
      return;
    }
    let shown = 0;
    const scored = Array.from(fgCards).map((c, i) => ({ card: c, score: scoreCard(c, query), idx: i }));
    scored.sort((a, b) => b.score - a.score || a.idx - b.idx);
    scored.forEach((s, order) => {
      if (s.score > 0) { s.card.classList.remove('hidden'); s.card.style.order = String(order); shown++; }
      else { s.card.classList.add('hidden'); s.card.style.order = ''; }
    });
    fgCount.textContent = shown + ' of ' + fgCards.length + ' species';
  }

  function renderSuggestions(query) {
    if (!query.trim()) { fgSuggestions.classList.remove('open'); fgSuggestions.innerHTML = ''; sugIdx = -1; return; }
    const scored = allBirds.map(b => ({ name: b, score: scoreBird(b, query) })).filter(b => b.score > 0).sort((a, b) => b.score - a.score).slice(0, 8);
    if (!scored.length) { fgSuggestions.classList.remove('open'); fgSuggestions.innerHTML = ''; sugIdx = -1; return; }
    sugIdx = -1;
    fgSuggestions.innerHTML = scored.map((b, i) => {
      const inGuide = spottedSet.has(b.name.toLowerCase());
      const gi = guideNames.indexOf(b.name.toLowerCase());
      const sci = gi >= 0 ? guideSci[gi] : '';
      return '<div class="fg-sug-item" data-idx="' + i + '" data-bird="' + b.name.replace(/"/g, '&quot;') + '">' +
        '<span><span class="fg-sug-name">' + b.name + '</span>' + (sci ? ' <span class="fg-sug-sci">' + sci + '</span>' : '') + '</span>' +
        '<span class="fg-sug-tag ' + (inGuide ? 'spotted' : 'unspotted') + '">' + (inGuide ? 'In Guide' : 'Not Spotted') + '</span>' +
        '</div>';
    }).join('');
    fgSuggestions.classList.add('open');
    fgSuggestions.querySelectorAll('.fg-sug-item').forEach(item => {
      item.addEventListener('click', () => { fgSearch.value = item.dataset.bird; fgSuggestions.classList.remove('open'); filterGrid(item.dataset.bird); });
    });
  }

  fgSearch?.addEventListener('input', (e) => { renderSuggestions(e.target.value); filterGrid(e.target.value); });
  fgSearch?.addEventListener('keydown', (e) => {
    const items = fgSuggestions.querySelectorAll('.fg-sug-item');
    if (!items.length) return;
    if (e.key === 'ArrowDown') { e.preventDefault(); sugIdx = Math.min(sugIdx + 1, items.length - 1); items.forEach((it, i) => it.classList.toggle('active', i === sugIdx)); }
    else if (e.key === 'ArrowUp') { e.preventDefault(); sugIdx = Math.max(sugIdx - 1, 0); items.forEach((it, i) => it.classList.toggle('active', i === sugIdx)); }
    else if (e.key === 'Enter' && sugIdx >= 0) { e.preventDefault(); const bird = items[sugIdx].dataset.bird; fgSearch.value = bird; fgSuggestions.classList.remove('open'); filterGrid(bird); }
    else if (e.key === 'Escape') { fgSuggestions.classList.remove('open'); }
  });
  document.addEventListener('click', (e) => { if (!e.target.closest('.fg-search-box')) fgSuggestions.classList.remove('open'); });
</script>
