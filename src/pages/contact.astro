---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact - Anthony Guzzardo" description="Get in touch with Anthony Guzzardo" background="frosted">
	<main class="socal">
		<p class="eyebrow">Contact</p>
		<h1>Let's make something <span class="sun">good</span></h1>

		<button class="email-copy" id="email-copy" type="button" data-email="anthony@mrfoxco.com" aria-label="Copy email address">
			<span class="email-copy-addr">anthony@mrfoxco.com</span>
			<span class="email-copy-hint">Click to copy</span>
			<span class="email-copy-done">Copied</span>
		</button>

		<p class="place"><a class="biz" href="https://mrfoxco.com" target="_blank" rel="noopener">Mr. Fox, LLC</a> · San Diego, CA · fully remote</p>
	</main>
</Layout>

<script>
	const btn = document.getElementById('email-copy');
	if (btn) {
		btn.addEventListener('click', async () => {
			const email = btn.dataset.email || '';
			try {
				await navigator.clipboard.writeText(email);
			} catch {
				// Fallback for older / insecure-context browsers
				const ta = document.createElement('textarea');
				ta.value = email;
				ta.style.position = 'fixed';
				ta.style.opacity = '0';
				document.body.appendChild(ta);
				ta.select();
				document.execCommand('copy');
				document.body.removeChild(ta);
			}
			btn.classList.add('copied');
			setTimeout(() => btn.classList.remove('copied'), 1600);
		});
	}
</script>
