---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Rangley - Meet People, Do Things"
	description="Rangley was a location-based social meetup app for iOS. Servers shut down March 2026."
>
	<!-- Hero Section -->
	<section class="rangley-hero">
		<div class="container">
			<div class="hero-content">
				<img src="/images/RangleyIconV2.png" alt="Rangley" class="hero-app-icon"/>
				<p class="project-status" style="margin-bottom: 1rem;">Shut Down — March 2026</p>
				<h1 class="rangley-hero-title">Your Social Compass</h1>
				<p class="rangley-hero-subtitle">Rangley was the fastest way to find spontaneous hangouts near you. No swiping. No small talk. Just real plans. Servers were shut down in March 2026.</p>
			</div>
		</div>
	</section>

	<!-- App Demo Section -->
	<section class="rangley-demo">
		<div class="container">
			<div class="demo-window">
				<div class="phone-mockup">
					<div class="phone-frame">
						<img src="/images/rangley/rangley-screenshot-main.png" alt="Rangley App Interface" class="phone-screen" />
					</div>
					<p class="demo-caption">Nearby meets shown in real-time</p>
				</div>
			</div>
		</div>
	</section>

	<!-- Features Section -->
	<section class="rangley-features" id="how-it-works">
		<div class="container">
			<h2 class="features-heading">How Rangley Worked</h2>

			<div class="feature-block">
				<div class="feature-content">
					<h3>See What's Happening</h3>
					<p>Users could open the app and instantly see nearby activities — coffee, tennis, group runs, or just hanging out. Everything was location-based and happening in real-time.</p>
				</div>
				<div class="feature-visual">
					<img src="/images/rangley/my_meets_sheet.png" alt="My Meets View" class="feature-img" />
				</div>
			</div>

			<div class="feature-block feature-block-reverse">
				<div class="feature-content">
					<h3>Create & Join Instantly</h3>
					<p>No swiping. No endless chatting. See a meet you were interested in? Tap to join. Want to organize something? Create a meet in seconds.</p>
				</div>
				<div class="feature-visual">
					<img src="/images/rangley/new_meet_Creation_flow/start.png" alt="Create Meet" class="feature-img" />
				</div>
			</div>

			<div class="feature-block">
				<div class="feature-content">
					<h3>Build Your Circle</h3>
					<p>Users could add friends, create groups, and organize private meets. The goal was building a network of people who actually showed up.</p>
				</div>
				<div class="feature-visual">
					<img src="/images/rangley/MeetGroups.png" alt="Meet Groups" class="feature-img" />
				</div>
			</div>

			<div class="feature-block feature-block-reverse">
				<div class="feature-content">
					<h3>Stay Connected</h3>
					<p>Users could see what friends were up to, check messages, and stay in the loop on what was happening around them.</p>
				</div>
				<div class="feature-visual">
					<img src="/images/rangley/new_inbox_photos.png" alt="Messages" class="feature-img" />
				</div>
			</div>
		</div>
	</section>

	<!-- Tech Stack Section -->
	<section class="rangley-stats">
		<div class="container">
			<div class="stats-grid">
				<div class="stat-card">
					<div class="stat-number">SwiftUI</div>
					<div class="stat-label">Frontend</div>
				</div>
				<div class="stat-card">
					<div class="stat-number">Vapor</div>
					<div class="stat-label">Backend</div>
				</div>
				<div class="stat-card">
					<div class="stat-number">AWS</div>
					<div class="stat-label">Infrastructure</div>
				</div>
			</div>
		</div>
	</section>

</Layout>
